                    '&u=' +
                    encodeURIComponent(d.URL) +
                    '&f=' +
                    +is_spa +
                    '&vn=' +
                    version +
                    (n ? '&c=' + n : '')
                );
                return settings_timer;
              },
            };
          window._vwo_settings_timer = code.init();
          return code;
        })();
    </script>
    <!-- End VWO Async SmartCode -->
  </head>
  {% liquid
    assign body_class = ''
    if template == 'article' or template == 'page.shogun.default'
      assign body_class = ' body-bg-white'
      if page.id == 96654983416 or page.id == 97919664376
        assign body_class = ''
      endif
    endif
  %}
  <body class="c-body{{ body_class }}">
    <a class="skip-to-content-link button visually-hidden sr-only" href="#MainContent">Skip content</a>
    {% section 'announcement-main' %}
    {% section 'header' %}
    <div class="c-header-spacing"></div>
    <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
    {% section 'cart' %}
    <!-- Google Tag Manager (noscript) MP -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-WGQ4SD7"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe
    ></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <div style="display:none;" id="af_hidepp_btn">
      <div class="additional-checkout-buttons">{{ content_for_additional_checkout_buttons }}</div>
    </div>

    {% include 'smile-initializer' %}

    <!-- Start Stamped.io code -->
    <script
      async
      type="text/javascript"
      id="stamped-script-widget"
      data-api-key="pubkey-2X5qdx5h6GBk4lOfd9gp2N02M6lDGR"
      src="https://cdn1.stamped.io/files/widget.min.js"
    ></script>
    <!-- Stamped - End script -->

    {% include 'stamped-rewards-init' %}
    <div style="display:none;" id="af_hidepp_btn">
      <div class="additional-checkout-buttons">{{ content_for_additional_checkout_buttons }}</div>
    </div>
    <div style="display:none;" id="af_hidepp_btn">
      <div class="additional-checkout-buttons">{{ content_for_additional_checkout_buttons }}</div>
    </div>
  </body>
</html>
