{% include 'shogun-content-handler' %}
<!doctype html>
<html class="no-js font-base font-normal font-body text-base text-black" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_button }}">
    <meta name="google-site-verification" content="UAZ5z-2m5C6xRLk4QJe1cR09itNNMqjfwlzr35U4THM">
    <meta name="facebook-domain-verification" content="zmnzvgtmocta3vw2vt37i060wkutq1">
    <meta name="p:domain_verify" content="dd9d23b996519357d26f89770cd0d3b0">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com">
    <link rel="dns-prefetch" href="https://productreviews.shopifycdn.com">
    <link rel="dns-prefetch" href="https://ajax.googleapis.com">
    <link rel="dns-prefetch" href="https://maps.googleapis.com">
    <link rel="dns-prefetch" href="https://maps.gstatic.com">
    {%- assign supported_locales = "en,ar" | split: "," -%}
{%- assign current_path = request.path | remove_first: '/ar' -%}

{%- comment -%} Canonical URL - always points to default English market {%- endcomment -%}
<link rel="canonical" href="https://newzealandhoneyco.ae{{ current_path }}" />

{%- comment -%} Alternate URLs for English and Arabic {%- endcomment -%}
{%- for locale in supported_locales -%}
  {%- if locale == 'en' -%}
    <link rel="alternate" href="https://newzealandhoneyco.ae{{ current_path }}" hreflang="en-AE" />
  {%- else -%}
    <link rel="alternate" href="https://newzealandhoneyco.ae/{{ locale }}{{ current_path }}" hreflang="ar-AE" />
  {%- endif -%}
{%- endfor -%}

{%- comment -%} x-default points to default English page {%- endcomment -%}
<link rel="alternate" href="https://newzealandhoneyco.ae{{ current_path }}" hreflang="x-default" />

{%- comment -%} Preload featured image on product pages {%- endcomment -%}
{% if template.name == 'product' %}
  <link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 800 }}">
{% endif %}

{%- comment -%} Favicon {%- endcomment -%}
{%- if settings.favicon != blank -%}
  <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
{%- endif -%}

{%- comment -%} Preconnect to Shopify fonts if using custom fonts {%- endcomment -%}
{%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
{%- endunless -%}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}
    {{ content_for_header }}
    <!-- Fonts -->
    {{ 'base.css' | asset_url | stylesheet_tag }}

    <script type="application/json" data-ajax-cart-initial-state>
      {{ cart | json }}
    </script>

    <script type="module">
      import '{{ "liquid-ajax-cart-v1.10.3.js" | asset_url }}';
    </script>

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    {% render 'shogun-head' %}
