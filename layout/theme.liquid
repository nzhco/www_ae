  {% comment %} OPUS CUSTOM {% endcomment %}
  <script>
    const currentURL = window.location.href;

    if (currentURL.includes("/cart")) {
      localStorage.setItem('opusOpenCustom', 'true');
      window.location.replace('https://newzealandhoneyco.ae');
    }

    document.addEventListener("DOMContentLoaded", function () {
      if (localStorage.getItem('opusOpenCustom')) {
        localStorage.removeItem('opusOpenCustom');
        setTimeout(() => {
          if (typeof window.opusOpen === "function") {
            window.opusOpen();
          }
        }, 1000);
      }
    });

  </script>
