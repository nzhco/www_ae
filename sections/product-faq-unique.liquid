{{ 'product-faq-unique.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_pair = false
  for i in (1..8)
    assign q_key = 'faq_q' | append: i
    assign a_key = 'faq_a' | append: i
    assign question = product.metafields.custom[q_key]
    assign answer = product.metafields.custom[a_key]
    if question != blank and answer != blank
      assign has_pair = true
      break
    endif
  endfor
-%}

{%- if has_pair -%}
  <div class="c-product-faq-unique__wrapper" style="--faq-accent: {{ product.metafields.custom.color | default: '#c8a86b' | escape }};">
    <div class="c-container">
      <div class="c-product-faq-unique__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="c-product-faq-unique__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}
      <div class="c-product-faq-unique__items">
        <div class="c-product-faq-unique__column">
          {%- for i in (1..4) -%}
            {%- liquid
              assign q_key = 'faq_q' | append: i
              assign a_key = 'faq_a' | append: i
              assign question = product.metafields.custom[q_key]
              assign answer = product.metafields.custom[a_key]
            -%}
            {%- if question != blank and answer != blank -%}
              <div class="c-product-faq-unique__item">
                <div class="c-product-faq-unique__item__title">
                  <h3>{{ question | escape }}</h3>
                  {%- render 'icon-arrow', type: '' -%}
                </div>
                <div class="c-product-faq-unique__item__description">
                  {{ answer }}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="c-product-faq-unique__column">
          {%- for i in (5..8) -%}
            {%- liquid
              assign q_key = 'faq_q' | append: i
              assign a_key = 'faq_a' | append: i
              assign question = product.metafields.custom[q_key]
              assign answer = product.metafields.custom[a_key]
            -%}
            {%- if question != blank and answer != blank -%}
              <div class="c-product-faq-unique__item">
                <div class="c-product-faq-unique__item__title">
                  <h3>{{ question | escape }}</h3>
                  {%- render 'icon-arrow', type: '' -%}
                </div>
                <div class="c-product-faq-unique__item__description">
                  {{ answer }}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      </div>
    </div>
  </div>
{%- endif -%}

{%- if has_pair -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- assign first_entry = true -%}
        {%- for i in (1..8) -%}
          {%- liquid
            assign q_key = 'faq_q' | append: i
            assign a_key = 'faq_a' | append: i
            assign question = product.metafields.custom[q_key]
            assign answer = product.metafields.custom[a_key]
          -%}
          {%- if question != blank and answer != blank -%}
            {%- unless first_entry -%},{%- endunless -%}
            {
              "@type": "Question",
              "name": {{ question | escape | json }},
              "acceptedAnswer": {
                "@type": "Answer",
                "text": {{ answer | strip_html | escape | json }}
              }
            }
            {%- assign first_entry = false -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

<script>
  (function() {
    var items = document.querySelectorAll('.c-product-faq-unique__item');
    if (!items.length) return;
    items.forEach(function(item) {
      var title = item.querySelector('.c-product-faq-unique__item__title');
      if (!title) return;
      title.addEventListener('click', function(e) {
        var parent = e.currentTarget.parentNode;
        if (parent.classList.contains('c-product-faq-unique__item--open')) {
          parent.classList.remove('c-product-faq-unique__item--open');
        } else {
          items.forEach(function(el) {
            el.classList.remove('c-product-faq-unique__item--open');
          });
          parent.classList.add('c-product-faq-unique__item--open');
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product FAQ (Unique)",
  "tag": "section",
  "class": "c-product-faq-unique",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "presets": [
    {
      "name": "Product FAQ (Unique)"
    }
  ]
}
{% endschema %}