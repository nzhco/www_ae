<script src="{{ 'clamp.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'stamped-reviews.js' | asset_url }}" defer="defer"></script>
{{ 'reviews.css' | asset_url | stylesheet_tag }}
{% if section.settings.show_title == false %}
  {%- if settings.public_api != blank -%}
    <div class="c-container" id="ratings">
      <style>
        --product-color: #f1b434;
      </style>
      <div
        class="c-reviews__content c-reviews--stamped"
        data-api="{{ settings.public_api }}"
        data-domain="{{ shop.domain }}"
        data-min="{{ section.settings.min_rating }}"
        {%- if section.settings.type == 'current' -%}
          data-product-id="{{ product.id }}"
          data-type="current"
        {%- else -%}
          data-type="all"
        {%- endif -%}
      >
        {%- if section.settings.title_text != blank -%}
          <h2>{{ section.settings.title_text | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.title_sub != blank -%}
          <p>{{ section.settings.title_sub }}</p>
        {%- endif -%}
        {%- if section.settings.type == 'current' -%}
          <div class="c-reviews__top">
            <div class="c-reviews__score c-reviews__score--hidden">
              <div class="c-reviews__rating">
                <div class="c-reviews__rating__info"></div>
                <div class="c-reviews__rating__stars">
                  <span class="c-reviews__rating__star">
                    <svg width="18" height="16" viewBox="0 0 18 16" fill="none" xmlns="http://www.w3.org/2000/svg">
