{{ 'announcement.css' | asset_url | stylesheet_tag }}

{%- capture announcement_icon_markup -%}
  <svg
    width="100%"
    height="100%"
    viewBox="0 0 24 24"
    version="1.1"
    xmlns="http://www.w3.org/2000/svg"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    xml:space="preserve"
    xmlns:serif="http://www.serif.com/"
    style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;"
  >
    <g transform="matrix(0.471041,0,0,0.490683,0.223978,0.199081)">
      <path d="M35.1,32.95L32.95,30.85L38.25,25.55L6,25.55L6,22.55L38.3,22.55L33,17.25L35.1,15.15L44,24.05L35.1,32.95Z" style="fill-rule:nonzero;" />
    </g>
  </svg>
{%- endcapture -%}

{%- capture announcement_nav_icon_markup -%}
  <svg class="icon icon-caret" viewBox="0 0 10 6" aria-hidden="true">
    <path fill="currentColor" fill-rule="evenodd" d="M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 0 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708" clip-rule="evenodd"></path>
  </svg>
{%- endcapture -%}

{% style %}
  #shopify-section-{{ section.id }} .announcement-bar {
    position: relative;
  }

  #shopify-section-{{ section.id }} .announcement-shell {
    position: relative;
  }

  #shopify-section-{{ section.id }} .announcement-frame {
    margin: 0 auto;
    max-width: 1350px;
    padding-left: 1rem;
    padding-right: 1rem;
    position: relative;
  }

  #shopify-section-{{ section.id }} .announcement-viewport {
    margin-left: 2rem;
    margin-right: 2rem;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .announcement-track {
    display: flex;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  #shopify-section-{{ section.id }} .announcement-slide {
    flex: 0 0 100%;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .announcement-slide .c-container {
    padding-left: 0;
    padding-right: 0;
  }

  #shopify-section-{{ section.id }} .announcement-nav {
    align-items: center;
    background: none;
    border: 0;
    color: var(--an-color, currentColor);
    cursor: pointer;
    display: inline-flex;
    height: 1.5rem;
    justify-content: center;
    padding: 0;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 1.5rem;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .announcement-nav--prev {
    left: 1rem;
  }

  #shopify-section-{{ section.id }} .announcement-nav--next {
    right: 1rem;
  }

  #shopify-section-{{ section.id }} .announcement-nav svg {
    height: auto;
    transform: rotate(-90deg);
    width: 0.875rem;
  }

  #shopify-section-{{ section.id }} .announcement-nav--prev svg {
    transform: rotate(90deg);
  }

  #shopify-section-{{ section.id }} .announcement-nav:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .announcement-frame {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }

    #shopify-section-{{ section.id }} .announcement-viewport {
      margin-left: 1.5rem;
      margin-right: 1.5rem;
    }

    #shopify-section-{{ section.id }} .announcement-nav {
      height: 1.25rem;
      width: 1.25rem;
    }

    #shopify-section-{{ section.id }} .announcement-nav--prev {
      left: 0.75rem;
    }

    #shopify-section-{{ section.id }} .announcement-nav--next {
      right: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .announcement-track {
      transition: none;
    }
  }
{% endstyle %}

{%- if section.blocks.size > 0 -%}
  {%- assign first_block = section.blocks.first -%}
  <div
    class="announcement-bar"
    data-announcement-slider
    data-autoplay="{{ section.settings.auto_rotate }}"
    data-interval="{{ section.settings.rotate_every | times: 1000 }}"
  >
    <div
      class="announcement-wrapper announcement-shell"
      data-announcement-wrapper
      {% if first_block.settings.color_text != blank or first_block.settings.color_bg != blank %}
        style="
          {% if first_block.settings.color_text != blank %}--an-color: {{ first_block.settings.color_text }};{% endif %}
          {% if first_block.settings.color_bg != blank %}--an-bg: {{ first_block.settings.color_bg }};{% endif %}
        "
      {% endif %}
    >
      <div class="announcement-frame">
        <div class="announcement-viewport">
          <div class="announcement-track" data-announcement-track>
          {%- for block in section.blocks -%}
            <div
              class="announcement-slide"
              {{ block.shopify_attributes }}
              data-announcement-slide
              data-text-color="{{ block.settings.color_text | escape }}"
              data-bg-color="{{ block.settings.color_bg | escape }}"
            >
              {%- if block.settings.link != blank -%}
                <a
                  href="{{ block.settings.link }}"
                  class="announcement-link"
                  rel="bookmark"
                >
                  <div class="c-container">
                    <div class="announcement-text">
                      {{ block.settings.text }}
                      {%- if block.settings.icon -%}
                        {{ announcement_icon_markup }}
                      {% endif %}
                    </div>
                  </div>
                </a>
              {%- else -%}
                <div class="c-container">
                  <div class="announcement-text">
                    {{ block.settings.text }}
                    {%- if block.settings.icon -%}
                      {{ announcement_icon_markup }}
                    {% endif %}
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
          </div>
        </div>
        {%- if section.blocks.size > 1 -%}
          <button
            type="button"
            class="announcement-nav announcement-nav--prev"
            aria-label="Previous announcement"
            data-announcement-prev
          >
            {{ announcement_nav_icon_markup }}
          </button>
          <button
            type="button"
            class="announcement-nav announcement-nav--next"
            aria-label="Next announcement"
            data-announcement-next
          >
            {{ announcement_nav_icon_markup }}
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

<script>
  (() => {
    const sectionId = 'shopify-section-{{ section.id }}';
    const sectionRoot = document.getElementById(sectionId);

    if (!sectionRoot) return;

    const slider = sectionRoot.querySelector('[data-announcement-slider]');
    const wrapper = sectionRoot.querySelector('[data-announcement-wrapper]');
    const track = sectionRoot.querySelector('[data-announcement-track]');
    const prevButton = sectionRoot.querySelector('[data-announcement-prev]');
    const nextButton = sectionRoot.querySelector('[data-announcement-next]');

    if (!slider || !wrapper || !track) return;

    const slides = Array.from(track.children);

    if (slides.length <= 1) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const autoplayEnabled = slider.dataset.autoplay === 'true' && !prefersReducedMotion;
    const interval = Number(slider.dataset.interval) || 5000;
    let activeIndex = 0;
    let timerId = null;

    const applySlideColors = () => {
      const activeSlide = slides[activeIndex];
      const textColor = activeSlide.dataset.textColor;
      const bgColor = activeSlide.dataset.bgColor;

      if (textColor) {
        wrapper.style.setProperty('--an-color', textColor);
      } else {
        wrapper.style.removeProperty('--an-color');
      }

      if (bgColor) {
        wrapper.style.setProperty('--an-bg', bgColor);
      } else {
        wrapper.style.removeProperty('--an-bg');
      }
    };

    const updateSlidePosition = () => {
      track.style.transform = `translateX(-${activeIndex * 100}%)`;
      applySlideColors();
    };

    const goToSlide = (index) => {
      activeIndex = (index + slides.length) % slides.length;
      updateSlidePosition();
    };

    const startAutoplay = () => {
      if (!autoplayEnabled || timerId) return;

      timerId = window.setInterval(() => {
        goToSlide(activeIndex + 1);
      }, interval);
    };

    const stopAutoplay = () => {
      if (!timerId) return;
      window.clearInterval(timerId);
      timerId = null;
    };

    const restartAutoplay = () => {
      stopAutoplay();
      startAutoplay();
    };

    slider.addEventListener('mouseenter', stopAutoplay);
    slider.addEventListener('mouseleave', startAutoplay);
    slider.addEventListener('focusin', stopAutoplay);
    slider.addEventListener('focusout', startAutoplay);

    if (prevButton) {
      prevButton.addEventListener('click', () => {
        goToSlide(activeIndex - 1);
        restartAutoplay();
      });
    }

    if (nextButton) {
      nextButton.addEventListener('click', () => {
        goToSlide(activeIndex + 1);
        restartAutoplay();
      });
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoplay();
      } else {
        startAutoplay();
      }
    });

    updateSlidePosition();
    startAutoplay();
  })();
</script>

{% schema %}
{
  "name": "Announcement",
  "tag": "section",
  "class": "announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate announcements",
      "default": true
    },
    {
      "type": "range",
      "id": "rotate_every",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Change slide every",
      "default": 5
    }
  ],
  "max_blocks": 10,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement item",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Our Manuka Honey</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "color_text",
          "label": "Text color",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "color_bg",
          "label": "Background color",
          "default": "#000000"
        },
        {
          "type": "checkbox",
          "id": "icon",
          "label": "Show icon",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
