{{ 'header.css' | asset_url | stylesheet_tag }}
{{ 'stamped-main.css' | asset_url | stylesheet_tag }}
<script src="{{ 'headroom.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'header.js' | asset_url }}" defer="defer"></script>
<div
  class="c-container c-header__container"
  {% if section.settings.sticky %}
    data-header-sticky
  {% endif %}
>
  <div class="c-header__content">
    <div class="c-header__left">
      {%- if section.settings.menu_mobile != blank -%}
        <div class="c-header__menu-toggle">
          <svg
            width="28"
            height="24"
            class="c-header__menu-toggle__open"
            viewBox="0 0 28 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path d="M7.5 1.5H21.5M2.5 8.5H25.5M1.5 15.5H26.5M2.5 22.5H25.5" stroke="black" stroke-width="3" stroke-linecap="round"/>
          </svg>
          <svg
            class="feather feather-x c-header__menu-toggle__close"
            fill="none"
            height="24"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            stroke="currentColor"
            viewbox="0 0 24 24"
            width="24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <line x1="18" x2="6" y1="6" y2="18"></line>
            <line x1="6" x2="18" y1="6" y2="18"></line>
          </svg>
        </div>
      {%- endif -%}
      {%- if section.settings.header_button_label != blank and section.settings.header_button_link != blank -%}
        <a href="{{ section.settings.header_button_link }}" rel="bookmark" class="c-header__button c-button">
          {{- section.settings.header_button_label | escape -}}
        </a>
      {% endif %}
      {%- if section.settings.menu_left != blank -%}
        <ul class="c-header__menu c-header__menu--left u-list-reset">
          {% for menu_item in section.settings.menu_left.links %}
            <li class="c-header__menu__item">
              <a
                class="c-header__menu__link{% if menu_item.active %} c-header__menu__link--active{% endif %}"
                href="{{ menu_item.url }}"
                title="{{ menu_item.title }}"
                rel="bookmark"
              >
                {{- menu_item.title -}}
              </a>
              {%- if menu_item.links != blank -%}
                <ul class="c-header__menu__sub">
                  {%- for sub_item in menu_item.links -%}
                    <li class="c-header__menu__sub__item{% if sub_item.active %} c-header__menu__sub__item--active{% endif %}">
                      <a href="{{ sub_item.url }}">{{ sub_item.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {% endfor %}
        </ul>
      {%- endif -%}
    </div>
    {%- if request.page_type == 'index' -%}
      <h1 class="c-header__branding">
        <a href="{{ routes.root_url }}">
