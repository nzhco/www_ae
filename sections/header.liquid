    <div class="c-header__right">
      {%- if section.settings.menu_right != blank -%}
        <ul class="c-header__menu c-header__menu--right u-list-reset">
          {% for menu_item in section.settings.menu_right.links %}
            <li class="c-header__menu__item">
              <a
                class="c-header__menu__link{% if menu_item.active %} c-header__menu__link--active{% endif %}"
                href="{{ menu_item.url }}"
                title="{{ menu_item.title }}"
                rel="bookmark"
              >
                {{- menu_item.title -}}
              </a>
              {%- if menu_item.links != blank -%}
                <ul class="c-header__menu__sub">
                  {%- for sub_item in menu_item.links -%}
                    <li class="c-header__menu__sub__item{% if sub_item.active %} c-header__menu__sub__item--active{% endif %}">
                      <a href="{{ sub_item.url }}">{{ sub_item.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {% endfor %}
        </ul>
      {%- endif -%}
      {%- if section.settings.show_user or section.settings.show_search or section.settings.show_cart -%}
        <div class="c-header__icons">
          {%- if section.settings.show_user and shop.customer_accounts_enabled -%}
            <a href="{{ routes.account_url }}" rel="nofollow" class="c-header__icon c-header__icon--user">
              <svg fill="none" height="23" viewbox="0 0 20 23" width="20" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.97595 12.76C13.2166 12.76 15.8437 10.1274 15.8437 6.88C15.8437 3.63257 13.2166 1 9.97595 1C6.73527 1 4.10817 3.63257 4.10817 6.88C4.10817 10.1274 6.73527 12.76 9.97595 12.76ZM9.97595 12.76C5.15599 12.76 1.24414 16.68 1.24414 21.51M9.97595 12.76C14.7959 12.76 18.7078 16.68 18.7078 21.51" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.93" stroke="#313131"/>
              </svg>
            </a>
          {% endif %}
          {%- if section.settings.show_search -%}
            <a href="{{ routes.search_url }}" rel="nofollow" class="c-header__icon c-header__icon--search">
              <svg fill="none" height="23" viewbox="0 0 23 23" width="23" xmlns="http://www.w3.org/2000/svg">
                <path d="M22 22L15.494 15.4968C18.8158 12.1765 18.8158 6.80148 15.494 3.49028C12.1813 0.169906 6.80402 0.169906 3.49137 3.49028C0.169543 6.80148 0.169543 12.1765 3.49137 15.4968C6.07909 18.0834 9.91479 18.6521 13.0531 17.2029" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.93" stroke="#313131"/>
              </svg>
            </a>
          {%- endif -%}
          {%- if section.settings.show_cart -%}
            <a
              data-ajax-cart-toggle-class-button="js-side-cart-open"
              href="{{ routes.cart_url }}"
              rel="nofollow"
              class="c-header__icon c-header__icon--cart"
            >
              <svg fill="none" height="23" viewbox="0 0 21 23" width="21" xmlns="http://www.w3.org/2000/svg">
                <path d="M15.0707 5.83H19.5114V21.33H1V5.83H11.4981M5.45073 5.83C5.45073 3.16 7.60624 1 10.2607 1C12.9152 1 15.0707 3.16 15.0707 5.82" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.93" stroke="#313131"/>
              </svg>
              <div data-ajax-cart-bind-state="cart.item_count">
                {{ cart.item_count }}
              </div>
            </a>
          {%- endif -%}
        </div>
      {% endif %}
     <div class="lan-switch-d-hide">
  <div class="language-switcher" style="display: inline-block; margin-left: 10px;">
    {% if request.path contains '/ar' %}
      {%- assign en_path = request.path | remove_first: '/ar' -%}
      <a href="https://newzealandhoneyco.ae{{ en_path }}" class="language-switcher__button">English</a>
    {% else %}
      <a href="https://newzealandhoneyco.ae/ar{{ request.path }}" class="language-switcher__button">العربية</a>
    {% endif %}
  </div>
</div>

    </div>
  </div>
</div>
{%- if section.settings.menu_mobile != blank -%}
  <div class="c-header__mobile-menu">
    <div class="c-container">
      <ul class="c-header__mobile-menu__list">
        {% for menu_item in section.settings.menu_mobile.links %}
          <li class="c-header__mobile-menu__item">
            <a
              class="c-header__mobile-menu__link{% if menu_item.active %} c-header__mobile-menu__link--active{% endif %}{% if menu_item.links != blank %} c-header__mobile-menu__link--has-children{% endif %}"
              href="{{ menu_item.url }}"
              title="{{ menu_item.title }}"
              rel="bookmark"
            >
              {{- menu_item.title -}}
              {%- if menu_item.links != blank -%}
                <svg
                  viewBox="0 0 24 24"
                  width="24"
                  height="24"
                  stroke="currentColor"
                  stroke-width="2"
                  fill="none"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="css-i6dzq1"
                >
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              {%- endif -%}
            </a>
            {%- if menu_item.links != blank -%}
              <ul class="c-header__mobile-menu__sub ">
                {%- for sub_item in menu_item.links -%}
                  <li class="c-header__mobile-menu__sub__item{% if sub_item.active %} c-header__mobile-menu__sub__item--active{% endif %}">
                    <a href="{{ sub_item.url }}">{{ sub_item.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {% endfor %}
      </ul>
      <p style="margin:25px 0px;;text-align:center;">
  <a href="{{ section.settings.header_button_link }}" style="padding: 10px 20px; background:#f1b434;color:#ffffff;border-radius: 25px;font-size:15px;">{{- section.settings.header_button_label | escape -}}</a>
</p> 
 <div class="language-switcher" style="text-align: center; padding: 10px 0;">
  {% if request.path contains '/ar' %}
  <div dir="ltr"><span>Switch to: </span> <a href="https://newzealandhoneyco.ae/" class="language-switcher__button">English</a></div>
    {% else %}
    <div dir="rtl"> <span>التبديل إلى:</span> <a href="https://newzealandhoneyco.ae/ar" class="language-switcher__button">العربية</a></div>
  {% endif %}
</div>
    </div>
  </div>
{%- endif -%}
<script src="{{ 'predictive-search.js' | asset_url }}" defer="defer"></script>
<predictive-search class="c-header__search">
  <div class="c-header__search__overlay"></div>
  <form action="{{ routes.search_url }}" method="get" role="search">
    <div class="c-header__search__row">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="css-i6dzq1"
      >
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <div class="c-header__search__input">
        <label for="Search">{{ 'sections.header.search' | t }}</label>
        <input
          id="Search"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          class="predictive-search-input"
          placeholder="{{ 'sections.header.placeholder' | t }}"
          {%- if settings.predictive_search_enabled -%}
            role="combobox"
            aria-expanded="false"
            aria-owns="predictive-search-results-list"
            aria-controls="predictive-search-results-list"
            aria-haspopup="listbox"
            aria-autocomplete="list"
            autocorrect="off"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
          {%- endif -%}
        >
        <div class="c-header__search__close">
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            stroke="currentColor"
            stroke-width="2"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="css-i6dzq1"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </div>
      </div>
    </div>
    <input name="options[prefix]" type="hidden" value="last">
    <div id="predictive-search" tabindex="-1"></div>
  </form>
</predictive-search>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "c-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu_left",
      "label": "Menu left"
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "Menu right"
    },
    {
      "type": "text",
      "id": "header_button_label",
      "label": "Button label",
      "default": "WHICH MANUKA IS FOR ME?"
    },
    {
      "type": "url",
      "id": "header_button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Make header sticky",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_user",
      "label": "User icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Cart icon",
      "default": true
    },
    {
      "type": "link_list",
      "id": "menu_mobile",
      "label": "Menu mobile"
    }
  ]
}
{% endschema %}
