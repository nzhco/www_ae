<script>
  (() => {
    if (window.__homeProductsAnchorSyncInitialized) return;
    window.__homeProductsAnchorSyncInitialized = true;

    const desktopQuery = window.matchMedia('(min-width: 990px)');

    const syncProductAnchors = () => {
      document.querySelectorAll('.c-home-products [data-product-anchor]').forEach((element) => {
        element.removeAttribute('id');
      });

      const visibleCardSelector = desktopQuery.matches
        ? '.c-home-products .c-home-products-desktop__card[data-product-anchor]'
        : '.c-home-products .c-home-product[data-product-anchor]';

      document.querySelectorAll(visibleCardSelector).forEach((element) => {
        element.id = element.dataset.productAnchor;
      });

      if (window.location.hash.length > 1) {
        const target = document.getElementById(window.location.hash.slice(1));
        if (target) {
          requestAnimationFrame(() => {
            target.scrollIntoView({ behavior: 'auto', block: 'start' });
          });
        }
      }
    };

    const initProductAnchorSync = () => {
      syncProductAnchors();
      window.addEventListener('hashchange', syncProductAnchors);

      if (desktopQuery.addEventListener) {
        desktopQuery.addEventListener('change', syncProductAnchors);
      } else if (desktopQuery.addListener) {
        desktopQuery.addListener(syncProductAnchors);
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductAnchorSync, { once: true });
    } else {
      initProductAnchorSync();
    }
  })();
</script>

