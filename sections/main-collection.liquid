<script src="{{ 'home-products.js' | asset_url }}" defer="defer"></script>
{{ 'home-products.css' | asset_url | stylesheet_tag }}
{{ 'consumberlab.css' | asset_url | stylesheet_tag }}
<style>
  @media (max-width: 575px) {
  .c-home-product__info__variants {
    display: none !important;
  }

  .new-ab-jan-mobile-hide {
    display: none !important;
  }
  .c-home-product__info__link a {
  background-color: var(--product-color) !important;
  color: #ffffff !important;
  width: 100%;
}

}
@media (max-width: 575px) {
  .product-badge {
    width: 100px !important;
  }
}
  .product-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 2;
  width: 140px; /* adjust as needed */
  height: auto;
}
.product-badge img {
  max-width: 100%;
  height: auto;
  display: block;
}

.c-home-product__image-corner-text {
  position: absolute;
  right: 12px;
  bottom: 12px;
  z-index: 11;
  max-width: calc(100% - 24px);
  font-size: 11px;
  font-weight: 500;
  line-height: 1.2;
  letter-spacing: 0.04em;
  text-align: right;
  color: #313131;
  text-shadow: 0 1px 2px rgba(255, 255, 255, 0.9);
}

.c-home-products .gw-rv-average-placeholder .gw-rv-average__btn {
  display: none !important;
}

.c-home-products .gw-rv-average-placeholder .gw-rv-average__rating_text {
  font-size: 12px !important;
}

</style>
<div class="c-container">
  <div class="c-home-products__content">
    {%- if section.settings.hide_title != true -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {% else %}
        <h2>{{ collection.title | escape }}</h2>
      {%- endif -%}
    {%- endif -%}
    {% comment %}theme-check-disable{% endcomment %}
    {%- assign products = collection.products | sort: 'published_at' -%}
    {% if section.settings.product_list != blank %}
      {% assign products = section.settings.product_list %}
    {% endif %}
    {% comment %}theme-check-enable{% endcomment %}
    {%- if section.settings.hide_umf != true -%}
{% comment %}Generating UMF and MGO score arrays with UMF priority{% endcomment %}
{% assign umf_scores = '' %}
{% assign mgo_scores = '' %}
{% assign umf_products = '' %}

{% for product in products %}
  {% if product.metafields.custom.umf_score != blank and product.metafields.custom.color != blank %}
    {%- unless umf_scores contains product.metafields.custom.umf_score -%}
      {% assign umf_scores = umf_scores
        | append: product.metafields.custom.umf_score
        | append: ':'
        | append: product.metafields.custom.color
        | append: ','
      %}
      {% assign umf_products = umf_products | append: product.id | append: ',' %}
    {% endunless %}
  {% endif %}
  {% if product.metafields.custom.mgo_score != blank and product.metafields.custom.color != blank %}
    {% unless umf_products contains product.id %}
      {%- unless mgo_scores contains product.metafields.custom.mgo_score -%}
        {% assign mgo_scores = mgo_scores
          | append: product.metafields.custom.mgo_score
          | append: ':'
          | append: product.metafields.custom.color
          | append: ','
        %}
      {% endunless %}
    {% endunless %}
  {% endif %}
{% endfor %}

{% assign umf_scores = umf_scores | split: ',' %}
{% assign mgo_scores = mgo_scores | split: ',' %}

<ul class="c-home-products__umf-nav u-list-reset">

  {% if mgo_scores and mgo_scores.size != 0 %}
    {% for mgo_score in mgo_scores %}
      {% liquid
        assign score_data = mgo_score | split: ':'
        assign score_value = score_data[0]
        assign score_color = score_data[1]
      %}
      {% if score_value != blank and score_color != blank %}
        <li>
          <a
            href="#mgo{{ score_value | replace: '+', '' | capitalize }}"
            style="--product-color: {{ score_color | escape }};"
          >
            MGO {{ score_value | escape }}
          </a>
        </li>
      {% endif %}
    {% endfor %}
  {% endif %}
  {% if umf_scores and umf_scores.size != 0 %}
    {% for umf_score in umf_scores %}
      {% liquid
        assign score_data = umf_score | split: ':'
        assign score_value = score_data[0]
        assign score_color = score_data[1]
      %}
      {% if score_value != blank and score_color != blank %}
        <li>
          <a
            href="#umf{{ score_value | replace: '+', '' | capitalize }}"
            style="--product-color: {{ score_color | escape }};"
          >
            UMF {{ score_value | escape }}
          </a>
        </li>
      {% endif %}
    {% endfor %}
  {% endif %}

</ul>

    {%- endif -%}

    <!-- Mobile product grid -->
    <div class="c-home-products__mobile-grid">
    <div class="c-home-products__list">
      {% for home_product in products %}
        {% liquid
          assign home_product_custom = home_product.metafields.custom
          assign default_variant_image = false
          assign default_variant_id = null
          if home_product.variants != blank
            for variant in home_product.variants
              if settings.default_variants contains variant.title
                assign default_variant_id = variant.id
                if variant.available == true and variant.featured_media != blank
                  assign default_variant_image = true
                endif
              endif
            endfor
          endif
        %}
        <div
            data-product-anchor="{{ home_product.handle }}"
            class="c-home-product"
            {% if home_product_custom.color != blank %}
              style="--product-color: {{ home_product_custom.color | escape }};"
            {% endif %}
          >
          <div
            class="c-home-product__image{% if home_product_custom.background_image != blank %} c-home-product__image--has-background{% else %} c-home-product__image--no-background{% endif %} {% if default_variant_image == true and default_variant_id != null %}show-variant{% endif %}"
            data-product-id="{{ home_product.id }}"
          >
            <a href="{{ home_product.url }}" rel="bookmark" class="u-absolute-fill">
              <div class="c-home-product__image__product u-absolute-fill">
                {% assign badge_image = home_product_custom.badge_image.value %}
                {% assign badge_link = home_product_custom.badge_link.value %}
                {% assign image_corner_text = home_product_custom.product_ship_only_text %}

                {% if badge_image != blank %}
                  <div class="product-badge">
                    {% if badge_link != blank %}
                      <a href="{{ badge_link }}" target="_blank" rel="noopener">
                        <img src="{{ badge_image }}" alt="Badge" loading="lazy">
                      </a>
                    {% else %}
                      <img src="{{ badge_image }}" alt="Badge" loading="lazy">
                    {% endif %}
                  </div>
                {% endif %}
                {%- if home_product.featured_media -%}
                  <div class="c-home-product__image__product__main u-absolute-fill">
                    <img
                      srcset="
                        {%- if home_product.featured_media.width >= 165 -%}{{ home_product.featured_media | image_url: width: 330 }} 165w,{%- endif -%}
                        {%- if home_product.featured_media.width >= 360 -%}{{ home_product.featured_media | image_url: width: 720 }} 360w,{%- endif -%}
                        {%- if home_product.featured_media.width >= 533 -%}{{ home_product.featured_media | image_url: width: 1128 }} 533w,{%- endif -%}
                        {%- if home_product.featured_media.width >= 720 -%}{{ home_product.featured_media | image_url: width: 1128 }} 720w,{%- endif -%}
                        {%- if home_product.featured_media.width >= 940 -%}{{ home_product.featured_media | image_url: width: 1128 }} 940w,{%- endif -%}
                        {%- if home_product.featured_media.width >= 1066 -%}{{ home_product.featured_media | image_url: width: 1128 }} 1066w,{%- endif -%}
                        {{ home_product.featured_media | image_url }} {{ home_product.featured_media.width }}w
                      "
                      src="{{ home_product.featured_media | image_url: width: 800 }}"
                      sizes="(min-width: 500px) {{ 1600 | minus: 500 | divided_by: 3 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                      alt="{{ home_product.featured_media.alt | escape }}"
                      class="u-absolute-fill c-home-product__image__primary"
                      loading="lazy"
                      width="{{ home_product.featured_media.width }}"
                      height="{{ home_product.featured_media.height }}"
                    >
                  </div>
                {%- endif -%}
                {%- if home_product.variants != blank -%}
                <div class="c-home-product__image__product__variants u-absolute-fill">
                  {%- assign sale_badge_shown = false -%}

                  {%- for variant in home_product.variants -%}
                    {%- if variant.featured_media != blank and variant.metafields.custom.hide != true -%}

                      <!-- SALE Badge Code -->
                      {%- if variant.metafields.custom.sale_badge != blank and sale_badge_shown == false -%}
                      <div class="sale-badge">
                        {{ variant.metafields.custom.sale_badge }}
                      </div>
                      {%- assign sale_badge_shown = true -%}
                      {%- endif -%}
                      <!-- End SALE Badge Code -->

                      <img
                        srcset="
                          {%- if variant.featured_media.width >= 165 -%}{{ variant.featured_media | image_url: width: 330 }} 165w,{%- endif -%}
                          {%- if variant.featured_media.width >= 360 -%}{{ variant.featured_media | image_url: width: 720 }} 360w,{%- endif -%}
                          {%- if variant.featured_media.width >= 533 -%}{{ variant.featured_media | image_url: width: 1128 }} 533w,{%- endif -%}
                          {%- if variant.featured_media.width >= 720 -%}{{ variant.featured_media | image_url: width: 1128 }} 720w,{%- endif -%}
                          {%- if variant.featured_media.width >= 940 -%}{{ variant.featured_media | image_url: width: 1128 }} 940w,{%- endif -%}
                          {%- if variant.featured_media.width >= 1066 -%}{{ variant.featured_media | image_url: width: 1128 }} 1066w,{%- endif -%}
                          {{ variant.featured_media | image_url }} {{ variant.featured_media.width }}w
                        "
                        src="{{ variant.featured_media | image_url: width: 800 }}"
                        sizes="(min-width: 500px) {{ 1600 | minus: 500 | divided_by: 3 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                        alt="{{ variant.featured_media.alt | escape }}"
                        class="u-absolute-fill c-home-product__image__primary c-home-product__image__primary--variant {% if default_variant_image == true and default_variant_id == variant.id %}show-variant-image{% endif %}"
                        data-variant-id="{{ variant.id }}"
                        loading="eager"
                        width="{{ variant.featured_media.width }}"
                        height="{{ variant.featured_media.height }}"
                      >
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- endif -%}
              </div>
              {%- if home_product_custom.background_image != blank -%}
                <img
                  srcset="
                    {%- if home_product_custom.background_image.width >= 165 -%}{{ home_product_custom.background_image | image_url: width: 330 }} 165w,{%- endif -%}
                    {%- if home_product_custom.background_image.width >= 360 -%}{{ home_product_custom.background_image | image_url: width: 720 }} 360w,{%- endif -%}
                    {%- if home_product_custom.background_image.width >= 533 -%}{{ home_product_custom.background_image | image_url: width: 1128 }} 533w,{%- endif -%}
                    {%- if home_product_custom.background_image.width >= 720 -%}{{ home_product_custom.background_image | image_url: width: 1128 }} 720w,{%- endif -%}
                    {%- if home_product_custom.background_image.width >= 940 -%}{{ home_product_custom.background_image | image_url: width: 1128 }} 940w,{%- endif -%}
                    {%- if home_product_custom.background_image.width >= 1066 -%}{{ home_product_custom.background_image | image_url: width: 1128 }} 1066w,{%- endif -%}
                    {{ home_product_custom.background_image | image_url }} {{ home_product_custom.background_image.width }}w
                  "
                  src="{{ home_product_custom.background_image | image_url: width: 800 }}"
                  sizes="(min-width: 500px) {{ 1600 | minus: 500 | divided_by: 3 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
                  alt="{{ home_product_custom.background_image.alt | escape }}"
                  class="u-absolute-fill c-home-product__image__background"
                  loading="lazy"
                  width="{{ home_product_custom.background_image.width }}"
                  height="{{ home_product_custom.background_image.height }}"
                >
              {%- endif -%}
              {% if image_corner_text != blank %}
                <span class="c-home-product__image-corner-text">{{ image_corner_text | escape }}</span>
              {% endif %}
            </a>
          </div>
          <div class="c-home-product__content">
            <div class="c-home-product__content__top">
              <div class="c-home-product__content__left">
                <div class="c-home-product__title">
                  <p class="c-home-product__title-text">
                    {{ home_product_custom.product_name | default: home_product.title | escape }}
                  </p>
                  <h3 class="c-home-product__score-line">
                  {%- assign has_score = false -%}
                  {%- if home_product_custom.umf_score != blank -%}
                    {%- assign has_score = true -%}
                    <span class="c-home-product__content__score c-home-product__content__score--umf">
                      <span class="c-home-product__content__score__name">
                        {{ 'sections.main_collection.umf_html' | t }}
                      </span>
                      <span class="c-home-product__content__score__value">
                        {{ home_product_custom.umf_score | escape }}
                      </span>
                    </span>
                  {%- endif -%}
                  {%- if home_product_custom.mgo_score != blank -%}
                    {%- if has_score -%}
                      <span class="c-home-product__score-separator">|</span>
                    {%- endif -%}
                    {%- assign has_score = true -%}
                    <span class="c-home-product__content__score c-home-product__content__score--mgo">
                      <span class="c-home-product__content__score__name">
                        {{ 'sections.main_collection.mgo' | t }}
                      </span>
                      <span class="c-home-product__content__score__value">
                        {{ home_product_custom.mgo_score | escape }}
                      </span>
                    </span>
                  {%- endif -%}
                  </h3>
                </div>
                <div class="c-home-product__rating__info">
                  <div
                    class="gw-rv-average-placeholder collections"
                    data-gw-product-id="{{ home_product.id }}"
                    style="display: block;font-size:15px;"
                  ></div>
                </div>
              </div>
            </div>
            <div class="c-home-product__content__description rte">
              {% if section.settings.product_content == 'full' %}
                {%- if home_product_custom.tagline != blank -%}
                  <p class="c-home-product__tagline">
                    <strong>{{ home_product_custom.tagline }}</strong>
                  </p>
                {%- endif -%}
                {%- if home_product.description != blank -%}
                  {{ home_product.description }}
                {%- endif -%}
              {%- else -%}
                {%- if home_product_custom.tagline != blank -%}
                  <p>
                    <strong>{{ home_product_custom.tagline }}</strong>
                  </p>
                {%- endif -%}
                {%- if home_product_custom.collection_short_description != blank -%}
                  <p class="c-home-product__short-description">{{ home_product_custom.collection_short_description }}</p>
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>
          <div class="c-home-product__info">
            {%- if home_product_custom.feature_1_image != blank
              or home_product_custom.feature_2_icon != blank
              or home_product_custom.feature_3_icon != blank
            -%}
              <div class="c-home-product__info__icons">
                {%- if home_product_custom.feature_1_image != blank
                  and home_product_custom.feature_1_description != blank
                -%}
                  <div class="c-home-product__info__icons__item">
                    <div class="c-home-product__info__icons__image">
                      {%- assign image_size = 75 | append: 'x' -%}
                      <img
                        srcset="{{ home_product_custom.feature_1_image | image_url: width: image_size }} 1x, {{ home_product_custom.feature_1_image | image_url: width: home_product_custom.feature_1_image.width }} 2x"
                        src="{{ home_product_custom.feature_1_image | image_url: width: image_size }}"
                        loading="lazy"
                        class="c-header__branding__img"
                        width="{{ home_product_custom.feature_1_image.width }}"
                        height="{{ home_product_custom.feature_1_image.height }}"
                        alt="{{ home_product_custom.feature_1_image.alt | default: home_product_custom.feature_1_description | escape }}"
                      >
                    </div>
                    <div class="c-home-product__info__icons__description">
                      <span>{{ home_product_custom.feature_1_description | escape }}</span>
                    </div>
                  </div>
                {%- endif -%}
                {%- if home_product_custom.feature_2_icon != blank
                  and home_product_custom.feature_2_description != blank
                -%}
                  <div class="c-home-product__info__icons__item">
                    <div class="c-home-product__info__icons__image">
                      {%- assign image_size = 75 | append: 'x' -%}
                      <img
                        srcset="{{ home_product_custom.feature_2_icon | image_url: width: image_size }} 1x, {{ home_product_custom.feature_2_icon | image_url: width: home_product_custom.feature_2_icon.width }} 2x"
                        src="{{ home_product_custom.feature_2_icon | image_url: width: image_size }}"
                        loading="lazy"
                        class="c-header__branding__img"
                        width="{{ home_product_custom.feature_2_icon.width }}"
                        height="{{ home_product_custom.feature_2_icon.height }}"
                        alt="{{ home_product_custom.feature_2_icon.alt | default: home_product_custom.feature_2_description | escape }}"
                      >
                    </div>
                    <div class="c-home-product__info__icons__description">
                      <span>{{ home_product_custom.feature_2_description | escape }}</span>
                    </div>
                  </div>
                {%- endif -%}
                {%- if home_product_custom.feature_3_icon != blank
                  and home_product_custom.feature_3_description != blank
                -%}
                  <div class="c-home-product__info__icons__item">
                    <div class="c-home-product__info__icons__image">
                      {%- assign image_size = 75 | append: 'x' -%}
                      <img
                        srcset="{{ home_product_custom.feature_3_icon | image_url: width: image_size }} 1x, {{ home_product_custom.feature_3_icon | image_url: width: home_product_custom.feature_3_icon.width }} 2x"
                        src="{{ home_product_custom.feature_3_icon | image_url: width: image_size }}"
                        loading="lazy"
                        class="c-header__branding__img"
                        width="{{ home_product_custom.feature_3_icon.width }}"
                        height="{{ home_product_custom.feature_3_icon.height }}"
                        alt="{{ home_product_custom.feature_3_icon.alt | default: home_product_custom.feature_3_description | escape }}"
                      >
                    </div>
                    <div class="c-home-product__info__icons__description">
                      <span>{{ home_product_custom.feature_3_description | escape }}</span>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- unless home_product.has_only_default_variant -%}
              <div class="c-home-product__info__variants">
                {%- for variant in home_product.variants -%}
                  {% assign default_variant_id = home_product.selected_or_first_available_variant.id %}
                  {%- if variant.metafields.custom.hide != true -%}
                    <a
                      href="{{ home_product.url }}{% if variant.available != false %}?variant={{ variant.id }}{% endif %}"
                      data-variant-id="{{ variant.id }}"
                      data-product-id="{{ home_product.id }}"
                      class="c-home-product__info__variant{% if default_variant_id == variant.id %} c-home-product__info__variant--active{% endif %}"
                      rel="bookmark"
                    >
                      <span class="c-home-product__info__variant__name">{{ variant.title | escape }}</span>
                      <span class="c-home-product__info__variant__price{% if variant.compare_at_price != null %} c-home-product__info__variant__price--has-sale{% endif %}">
                        {% if variant.compare_at_price != null %}
                          <del>{{ variant.price | money }}</del><ins>{{ variant.compare_at_price | money }}</ins>
                        {% else %}
                          <span>{{ variant.price | money }}</span>
                        {% endif %}
                      </span>
                    </a>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endunless -%}
            <div class="c-home-product__info__link">
              <a
                href="{{ home_product.url }}{% if default_variant_id != null %}?variant={{ default_variant_id }}{% endif %}"
                rel="bookmark"
              >
                {%- if home_product_custom.shop_button_text != blank -%}
                  {{- home_product_custom.shop_button_text | escape -}}
                {%- else -%}
                  {{ 'sections.main_collection.learn_more' | t }}
                {%- endif -%}
              </a>
            </div>
          </div>
        </div>

        {% if section.settings.show_mid_banner and forloop.index == section.settings.banner_position %}
          <div
            class="c-home-products__banner"
            style="--banner-bg: {{ section.settings.banner_bg_color }}; --banner-text: {{ section.settings.banner_text_color }}; --banner-button-bg: {{ section.settings.banner_button_bg_color }}; --banner-button-text: {{ section.settings.banner_button_text_color }};"
          >
            <div class="c-home-products__banner-content">
              {% if section.settings.banner_heading != blank %}
                <h3 class="c-home-products__banner-text">{{ section.settings.banner_heading }}</h3>
              {% endif %}

              {% if section.settings.banner_button_text != blank %}
                {% if section.settings.banner_button_link != blank %}
                  <a href="{{ section.settings.banner_button_link }}" class="c-home-products__banner-btn">
                    {{ section.settings.banner_button_text | escape }}
                  </a>
                {% else %}
                  <span class="c-home-products__banner-btn">
                    {{ section.settings.banner_button_text | escape }}
                  </span>
                {% endif %}
              {% endif %}
            </div>

            {% if section.settings.banner_image != blank %}
              <div class="c-home-products__banner-image">
                <img
                  srcset="
                    {{ section.settings.banner_image | image_url: width: 260 }} 260w,
                    {{ section.settings.banner_image | image_url: width: 520 }} 520w
                  "
                  src="{{ section.settings.banner_image | image_url: width: 520 }}"
                  alt="{{ section.settings.banner_image.alt | default: section.settings.banner_heading | strip_html | escape }}"
                  loading="lazy"
                  width="{{ section.settings.banner_image.width }}"
                  height="{{ section.settings.banner_image.height }}"
                >
              </div>
            {% endif %}
          </div>
        {% endif %}

      {% endfor %}
    </div>
    </div>

    <!-- Desktop product grid -->
    <div class="c-home-products-desktop">
      <div class="c-home-products-desktop__grid">
        {% for home_product in products %}
          {% assign home_product_custom = home_product.metafields.custom %}
          <article
            data-product-anchor="{{ home_product.handle }}"
            class="c-home-products-desktop__card"
            {% if home_product_custom.color != blank %}
              style="--desktop-product-color: {{ home_product_custom.color | escape }};"
            {% endif %}
          >
            <div class="c-home-products-desktop__media">
              {% assign badge_image = home_product_custom.badge_image.value %}
              {% assign badge_link = home_product_custom.badge_link.value %}
              {% assign image_corner_text = home_product_custom.product_ship_only_text %}

              {% if badge_image != blank %}
                <div class="c-home-products-desktop__badge">
                  {% if badge_link != blank %}
                    <a href="{{ badge_link }}" target="_blank" rel="noopener">
                      <img src="{{ badge_image }}" alt="Badge" loading="lazy">
                    </a>
                  {% else %}
                    <img src="{{ badge_image }}" alt="Badge" loading="lazy">
                  {% endif %}
                </div>
              {% endif %}

              <a
                href="{{ home_product.url }}"
                rel="bookmark"
                class="c-home-products-desktop__media-link"
                aria-label="{{ home_product_custom.product_name | default: home_product.title | escape }}"
              >
                {% if home_product_custom.background_image != blank %}
                  <img
                    srcset="
