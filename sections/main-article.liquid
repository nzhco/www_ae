{{ 'comments.css' | asset_url | stylesheet_tag }}
{{ 'form.css' | asset_url | stylesheet_tag }}
{{ 'article.css' | asset_url | stylesheet_tag }}
{{ 'rte.css' | asset_url | stylesheet_tag }}
{% if section.settings.container == false %}
  <div class="c-container">
    {% if section.settings.meta == false %}
      <ul class="c-article__meta{% if section.settings.wide == true %} c-article__wide{% endif %}">
        {% if article.tags != blank %}
          {% assign first_tag = article.tags | first %}
          <li class="c-article__meta__tag">{{ first_tag | link_to_tag: first_tag }}</li>
        {% endif %}
        <li class="c-article__meta__date">{{ article.published_at | date: '%B %d, %y' }}</li>
      </ul>
    {% endif %}
    {% if section.settings.title == false %}
      <h1 class="c-article__title{% if section.settings.wide == true %} c-article__wide{% endif %}">
        {{ article.title }}
      </h1>
    {% endif %}
    {% if section.settings.image == false and article.image != blank %}
      <div class="c-article__image">
        {{
          article.image
          | image_url: width: article.image.width
          | image_tag: height: article.image.height, alt: article.image.alt, class: 'u-absolute-fill', loading: 'lazy'
        }}
      </div>
    {% endif %}
    <div class="c-article__content c-rte{% if section.settings.wide == true %} c-article__wide{% endif %}">
      {{ article.content }}
    </div>
    {% if section.settings.share == false %}
      <div class="c-article__share{% if section.settings.wide == true %} c-article__wide{% endif %}">
        <div class="c-article__share__icons">
          <a
            target="_blank"
            rel="noopener"
            href="//www.facebook.com/sharer.php?u={{ article.url }}"
            class="social-sharing__link"
            title="{{ 'sections.main_article.facebook' | t }}"
          >
            <svg
              aria-hidden="true"
              focusable="false"
              role="presentation"
              class="icon icon-facebook"
              viewBox="0 0 32 32"
            >
              <path fill="#444" d="M18.56 31.36V17.28h4.48l.64-5.12h-5.12v-3.2c0-1.28.64-2.56 2.56-2.56h2.56V1.28H19.2c-3.84 0-7.04 2.56-7.04 7.04v3.84H7.68v5.12h4.48v14.08h6.4z"></path>
            </svg>
            <span class="social-sharing__title" aria-hidden="true">{{ 'sections.main_article.share' | t }}</span>
            <span class="visually-hidden">{{ 'sections.main_article.facebook' | t }}</span> </a
          ><a
            target="_blank"
            rel="noopener"
            href="//twitter.com/share?text=Manuka%20Honey%20for%20Pregnancy%20and%20Recovery&amp;url={{ article.url }}"
            class="social-sharing__link"
            title="{{ 'sections.main_article.twitter' | t }}"
          >
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-twitter" viewBox="0 0 32 32">
              <path fill="#444" d="M31.281 6.733q-1.304 1.924-3.13 3.26 0 .13.033.408t.033.408q0 2.543-.75 5.086t-2.282 4.858-3.635 4.108-5.053 2.869-6.341 1.076q-5.282 0-9.65-2.836.913.065 1.5.065 4.401 0 7.857-2.673-2.054-.033-3.668-1.255t-2.266-3.146q.554.13 1.206.13.88 0 1.663-.261-2.184-.456-3.619-2.184t-1.435-3.977v-.065q1.239.652 2.836.717-1.271-.848-2.021-2.233t-.75-2.983q0-1.63.815-3.195 2.38 2.967 5.754 4.678t7.319 1.907q-.228-.815-.228-1.434 0-2.608 1.858-4.45t4.532-1.842q1.304 0 2.51.522t2.054 1.467q2.152-.424 4.01-1.532-.685 2.217-2.771 3.488 1.989-.261 3.619-.978z"></path>
            </svg>
            <span class="social-sharing__title" aria-hidden="true">{{ 'sections.main_article.tweet' | t }}</span>
            <span class="visually-hidden">{{ 'sections.main_article.twitter' | t }}</span> </a
          ><a
            target="_blank"
            rel="noopener"
            href="//pinterest.com/pin/create/button/?url={{ article.url }}&amp;description={{ article.title | escape }}"
            class="social-sharing__link"
            title="{{ 'sections.main_article.pinterest' | t }}"
          >
            <svg
              aria-hidden="true"
              focusable="false"
              role="presentation"
              class="icon icon-pinterest"
              viewBox="0 0 32 32"
            >
              <path fill="#444" d="M27.52 9.6c-.64-5.76-6.4-8.32-12.8-7.68-4.48.64-9.6 4.48-9.6 10.24 0 3.2.64 5.76 3.84 6.4 1.28-2.56-.64-3.2-.64-4.48-1.28-7.04 8.32-12.16 13.44-7.04 3.2 3.84 1.28 14.08-4.48 13.44-5.12-1.28 2.56-9.6-1.92-11.52-3.2-1.28-5.12 4.48-3.84 7.04-1.28 4.48-3.2 8.96-1.92 15.36 2.56-1.92 3.84-5.76 4.48-9.6 1.28.64 1.92 1.92 3.84 1.92 6.4-.64 10.24-7.68 9.6-14.08z"></path>
            </svg>
            <span class="social-sharing__title" aria-hidden="true">{{ 'sections.main_article.pin' | t }}</span>
            <span class="visually-hidden">{{ 'sections.main_article.pinterest' | t }}</span>
          </a>
        </div>
      </div>
    {% endif %}
    {%- if blog.comments_enabled? -%}
      <div id="comments" class="c-comments{% if section.settings.wide == true %} c-article__wide{% endif %}">
        {%- if article.comments_count > 0 -%}
          {%- assign anchorId = '#Comments-' | append: article.id -%}

          <h2 id="Comments-{{ article.id }}">
            {{ article.comments_count }}
            {% if article.comments_count > 1 -%}
              {{- 'sections.main_article.comments' | t -}}
            {%- else -%}
              {{- 'sections.main_article.comment' | t -}}
            {%- endif %}
          </h2>
          {% paginate article.comments by 5 %}
            <div class="c-comments__list">
              {%- if comment.status == 'pending' and comment.content -%}
                <article id="{{ comment.id }}" class="c-comment">
                  {{ comment.content }}
                  <footer>
                    <span class="c-comment_author">{{ comment.author }}</span>
                  </footer>
                </article>
              {%- endif -%}

              {%- for comment in article.comments -%}
                <article id="{{ comment.id }}" class="c-comment">
                  {{ comment.content }}
                  <footer>
                    <span class="c-comment__author">{{ comment.author }}</span
                    ><span class="c-comment__date">{{ comment.created_at | time_tag: format: 'date' }}</span>
                  </footer>
                </article>
              {%- endfor -%}
              {%- if paginate.parts.size > 0 -%}
                <ul class="c-comments__list__pagination" role="list">
                  {%- for part in paginate.parts -%}
                    <li>
                      {%- if part.is_link -%}
                        <a
                          href="{{ part.url }}{{ anchorId }}"
                          class="c-comments__list__pagination__item"
                          aria-label="{{ 'pagination.page' | t: number: part.title }}"
                        >
                          {{- part.title -}}
                        </a>
                      {%- else -%}
                        {%- if part.title == paginate.current_page -%}
                          <a
                            role="link"
                            aria-disabled="true"
                            class="c-comments__list__pagination__item c-comments__list__pagination__item--current"
                            aria-current="page"
                            aria-label="{{ 'pagination.page' | t: number: part.title }}"
                          >
                            {{- part.title -}}
                          </a>
                        {%- else -%}
                          <span class="c-comments__list__pagination__item">{{ part.title }}</span>
                        {%- endif -%}
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {% endpaginate %}
        {%- endif -%}
        {% form 'new_comment', article %}
          {%- liquid
            assign post_message = 'Your comment was posted successfully! Thank you!'
            if blog.moderated? and comment.status == 'unapproved'
              assign post_message = 'Your comment was posted successfully. We will publish it in a little while, as our blog is moderated.'
            endif
          -%}
          <h2>{{ 'sections.main_article.leave_comment' | t }}</h2>
          {%- if form.errors -%}
            <div class="c-form__message c-form__message--error" role="alert">
              <h3>{{ 'sections.main_article.comment_message' | t }}</h3>
              <ul>
                {%- for field in form.errors -%}
                  <li>
                    <a href="#CommentForm-{{ field }}" class="link">
                      {%- if form.errors.translated_fields[field] contains 'author' -%}
                        {{ 'sections.main_article.message_name' | t }}
                      {%- elsif form.errors.translated_fields[field] contains 'body' -%}
                        {{ 'sections.main_article.message_comment' | t }}
                      {%- else -%}
                        {{ form.errors.translated_fields[field] }}
                      {%- endif -%}
                      {{ form.errors.messages[field] }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- elsif form.posted_successfully? -%}
            <div class="c-form__message c-form__message--success" role="status">
              <h3>{{ post_message }}</h3>
            </div>
          {%- endif -%}

          <div
            {% if blog.moderated? == false %}
              class="article-template__comments-fields"
            {% endif %}
          >
            <div class="c-form__fields">
              <div class="c-form__field c-form__field--with-error">
                <input
                  type="text"
                  name="comment[author]"
                  id="CommentForm-author"
                  class="c-form__field__input"
                  autocomplete="name"
                  value="{{ form.author }}"
                  aria-required="true"
                  required
                  {% if form.errors contains 'author' %}
                    aria-invalid="true"
                    aria-describedby="CommentForm-author-error"
                  {% endif %}
                  placeholder="{{ 'sections.main_article.placeholder_name' | t }}"
                >
                <label
                  class="c-form__field__label"
                  for="CommentForm-author"
                >
                  {{- 'sections.main_article.label_name' | t }}
                  <span aria-hidden="true">*</span></label
                >
                {%- if form.errors contains 'author' -%}
                  <small class="c-form__field__error" id="CommentForm-author-error">
                    <span class="form__message">
                      {{- 'sections.main_article.warning_name' | t }}
                      {{ form.errors.messages.author }}.</span
                    >
                  </small>
                {%- endif -%}
              </div>
              <div class="c-form__field c-form__field--with-error">
                <input
                  type="email"
                  name="comment[email]"
                  id="CommentForm-email"
                  autocomplete="email"
                  class="c-form__field__input"
                  value="{{ form.email }}"
                  autocorrect="off"
                  autocapitalize="off"
                  aria-required="true"
                  required
                  {% if form.errors contains 'email' %}
                    aria-invalid="true"
                    aria-describedby="CommentForm-email-error"
                  {% endif %}
                  placeholder="{{ 'sections.main_article.placeholder_email' | t }}"
                >
                <label
                  class="c-form__field__label"
                  for="CommentForm-email"
                >
                  {{- 'sections.main_article.label_email' | t }}
                  <span aria-hidden="true">*</span></label
                >
                {%- if form.errors contains 'email' -%}
                  <small class="c-form__field__error" id="CommentForm-email-error">
                    <span class="form__message">
                      {{- 'sections.main_article.warning_email' | t }}
                      {{ form.errors.messages.email }}.</span
                    >
                  </small>
                {%- endif -%}
              </div>
            </div>
            <div class="c-form__field c-form__field--with-error">
              <textarea
                rows="5"
                name="comment[body]"
                id="CommentForm-body"
                class="text-area c-form__field__input"
                aria-required="true"
                required
                {% if form.errors contains 'body' %}
                  aria-invalid="true"
                  aria-describedby="CommentForm-body-error"
                {% endif %}
                placeholder="{{ 'sections.main_article.placeholder_comment' | t }}"
              >{{ form.body }}</textarea>
              <label
                class="form__label c-form__field__label"
                for="CommentForm-body"
              >
                {{- 'sections.main_article.label_comment' | t }}
                <span aria-hidden="true">*</span></label
              >
            </div>
            {%- if form.errors contains 'body' -%}
              <small class="c-form__field__error" id="CommentForm-body-error">
                <span class="form__message">
                  {{- 'sections.main_article.warning_comment' | t }}
                  {{ form.errors.messages.body }}.</span
                >
              </small>
            {%- endif -%}
          </div>
          {%- if blog.moderated? -%}
            <p class="c-form__moderate-message">{{ 'sections.main_article.moderate' | t }}</p>
          {%- endif -%}
          <input type="submit" class="c-form__button c-button" value="{{ 'sections.main_article.add_comment' | t }}">
        {% endform %}
      </div>
    {%- endif -%}
  </div>
{% else %}
  {{ article.content }}
{% endif %}
<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Article",
    "articleBody": {{ article.content | strip_html | json }},
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ request.origin | append: page.url | json }}
    },
    "headline": {{ article.title | json }},
    {% if article.excerpt != blank %}
      "description": {{ article.excerpt | strip_html | json }},
    {% endif %}
    {% if article.image %}
      "image": [
        {{ article | image_url: width: article.image.width | prepend: "https:" | json }}
      ],
    {% endif %}
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "dateCreated": {{ article.created_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "publisher": {
      "@type": "Organization",
      {% if settings.share_image %}
        "logo": {
          "@type": "ImageObject",
          "height": {{ settings.share_image.height | json }},
          "url": {{ settings.share_image | image_url: width: settings.share_image.width | prepend: "https:" | json }},
          "width": {{ settings.share_image.width | json }}
        },
      {% endif %}
      "name": {{ shop.name | json }}
    }
  }
</script>

{% schema %}
{
  "name": "Main Article",
  "tag": "article",
  "class": "c-article",
  "settings": [
    {
      "type": "checkbox",
      "id": "meta",
      "label": "Hide Meta",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "title",
      "label": "Hide Title",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "image",
      "label": "Hide Featured Image",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "wide",
      "label": "Wide Content",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "container",
      "label": "Disable Container",
      "info": "It useful for when using a Shogun page builder",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "share",
      "label": "Hide Social",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Main Article"
    }
  ]
}
{% endschema %}
