              <a class="c-article__product-image" href="{{ article_sidebar_product.url }}" aria-label="{{ article_sidebar_product.title | escape }}">
                <img
                  src="{{ article_sidebar_product.featured_image | image_url: width: 420 }}"
                  alt="{{ article_sidebar_product.featured_image.alt | default: article_sidebar_product.title | escape }}"
                  width="{{ article_sidebar_product.featured_image.width }}"
                  height="{{ article_sidebar_product.featured_image.height }}"
                  loading="lazy"
                >
              </a>
            {%- endif -%}

            <div class="c-article__product-content">
              {%- if sidebar_product_review_average != blank or sidebar_product_review_count != blank -%}
                <div class="c-article__product-reviews">
                  <span class="c-article__product-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  {%- if sidebar_product_review_average != blank -%}
                    <span>{{ sidebar_product_review_average | round: 2 }}</span>
                  {%- endif -%}
                  {%- if sidebar_product_review_count != blank -%}
                    <span>({{ sidebar_product_review_count }})</span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if sidebar_product_umf_score != blank or sidebar_product_mgo_score != blank -%}
                <div class="c-article__product-scores">
                  {%- if sidebar_product_umf_score != blank -%}
                    <span
                      class="c-article__product-score{% if sidebar_product_badge_color != blank %} c-article__product-score--accent{% endif %}"
                      {% if sidebar_product_badge_color != blank %}
                        style="background-color: {{ sidebar_product_badge_color | escape }}; border-color: {{ sidebar_product_badge_color | escape }};"
                      {% endif %}
                    >
                      UMF {{ sidebar_product_umf_score }}
                    </span>
                  {%- endif -%}
                  {%- if sidebar_product_mgo_score != blank -%}
                    <span
                      class="c-article__product-score{% if sidebar_product_badge_color != blank %} c-article__product-score--accent{% endif %}"
                      {% if sidebar_product_badge_color != blank %}
                        style="background-color: {{ sidebar_product_badge_color | escape }}; border-color: {{ sidebar_product_badge_color | escape }};"
                      {% endif %}
                    >
                      MGO {{ sidebar_product_mgo_score }}
                    </span>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if sidebar_product_short_description != blank -%}
                <div class="c-article__product-description">
                  {%- if sidebar_product_short_description.type != blank -%}
                    {{ sidebar_product_short_description | metafield_tag }}
                  {%- else -%}
                    {{ sidebar_product_short_description }}
                  {%- endif -%}
                </div>
              {%- endif -%}

              <a class="c-article__product-button" href="{{ article_sidebar_product.url }}">Shop now</a>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- if article_sidebar_promo_enabled and article_sidebar_promo_position == 'below_product' and article_sidebar_product != blank -%}
        {{ article_sidebar_promo_markup }}
      {%- endif -%}

      {%- if article_sidebar_promo_enabled and article_sidebar_promo_position == 'below_product' and article_sidebar_product == blank -%}
        {{ article_sidebar_promo_markup }}
      {%- endif -%}
    </aside>
  {%- endif -%}
{%- endcapture -%}

{%- capture article_header_markup -%}
