<script>
  let lastScrollTop = 0;
  const progressBarContainer = document.querySelector('.progress-bar-container');
  const progressBar = document.querySelector('.progress-bar');
  let updateActiveTableOfContents = null;

  function updateProgressBar() {
    const totalHeight = document.body.scrollHeight - window.innerHeight;
    const progress = (window.pageYOffset / totalHeight) * 100;
    if (progressBar) progressBar.style.width = progress + '%';
  }

  function slugifyHeadingText(value) {
    return (value || '')
      .toString()
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/&/g, ' and ')
      .replace(/['’]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '') || 'section';
  }

  function normalizeHeadingText(value) {
    return (value || '')
      .toString()
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/&/g, ' and ')
      .replace(/['’]/g, '')
      .replace(/[^a-z0-9]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function getSidebarScrollOffset(sectionRoot) {
    const sidebar = sectionRoot ? sectionRoot.querySelector('.c-article__sidebar') : null;
    const stickyTop = sidebar ? parseInt(window.getComputedStyle(sidebar).top, 10) : NaN;

    if (Number.isFinite(stickyTop)) {
      return stickyTop + 28;
    }

    return 112;
  }

  function initializeSidebarTableOfContents() {
    const sectionRoot = document.currentScript ? document.currentScript.closest('.c-article') : document.querySelector('.c-article');
    const articleBody = sectionRoot ? sectionRoot.querySelector('.c-article__body-main') : null;
    const sidebarCard = sectionRoot ? sectionRoot.querySelector('[data-sidebar-content-card]') : null;
    const sidebarContent = sidebarCard ? sidebarCard.querySelector('[data-sidebar-content]') : null;

    if (!articleBody || !sidebarCard || !sidebarContent) {
      return;
    }

    const headingElements = Array.from(articleBody.querySelectorAll('h2, h3, h4, h5, h6')).filter(function (heading) {
      return normalizeHeadingText(heading.textContent) !== '';
    });

    if (!headingElements.length) {
      return;
    }

    const usedIds = new Set();
    const headingEntries = headingElements.map(function (heading) {
      let headingId = heading.id ? heading.id.trim() : '';
      const baseId = headingId || slugifyHeadingText(heading.textContent);
      let uniqueId = baseId;
      let suffix = 2;

      while (usedIds.has(uniqueId)) {
        uniqueId = baseId + '-' + suffix;
        suffix += 1;
      }

      if (headingId !== uniqueId) {
        heading.id = uniqueId;
      }

      usedIds.add(uniqueId);

      return {
        element: heading,
        id: uniqueId,
        text: normalizeHeadingText(heading.textContent)
      };
    });

    const headingMap = new Map();

    headingEntries.forEach(function (entry) {
      if (!headingMap.has(entry.text)) {
        headingMap.set(entry.text, entry);
      }
    });

    const tocItemElements = Array.from(sidebarContent.querySelectorAll('p, li, h1, h2, h3, h4, h5, h6')).filter(function (item) {
      return normalizeHeadingText(item.textContent) !== '';
    });

    const matchedItems = tocItemElements.map(function (item) {
      const itemText = normalizeHeadingText(item.textContent);
      let matchedHeading = headingMap.get(itemText) || null;

      if (!matchedHeading) {
        matchedHeading = headingEntries.find(function (entry) {
          return entry.text.includes(itemText) || itemText.includes(entry.text);
        }) || null;
      }

      if (!matchedHeading) {
        return null;
      }

      let link = item.querySelector('a');

      if (!link) {
        link = document.createElement('a');
        link.className = 'c-article__toc-link';
        link.innerHTML = item.innerHTML;
        item.innerHTML = '';
        item.appendChild(link);
      } else {
        link.classList.add('c-article__toc-link');
      }

      link.setAttribute('href', '#' + matchedHeading.id);
      link.setAttribute('data-toc-target', matchedHeading.id);

      return {
        item: item,
        link: link,
        heading: matchedHeading.element,
        id: matchedHeading.id
      };
    }).filter(Boolean);

    if (matchedItems.length < 2) {
      return;
    }

    sidebarCard.classList.add('c-article__sidebar-card--toc');

    matchedItems.forEach(function (entry) {
      entry.link.addEventListener('click', function (event) {
        event.preventDefault();

        const scrollOffset = getSidebarScrollOffset(sectionRoot);
        const targetTop = entry.heading.getBoundingClientRect().top + window.pageYOffset - scrollOffset;

        window.scrollTo({
          top: Math.max(targetTop, 0),
          behavior: 'smooth'
        });

        if (window.history && window.history.replaceState) {
          window.history.replaceState(null, '', '#' + entry.id);
        }
      });
    });

    const orderedItems = matchedItems.slice().sort(function (left, right) {
      return left.heading.offsetTop - right.heading.offsetTop;
    });

    function setActiveTableOfContentsItem(activeId) {
      matchedItems.forEach(function (entry) {
        const isActive = entry.id === activeId;
        entry.link.classList.toggle('is-active', isActive);

        if (isActive) {
          entry.link.setAttribute('aria-current', 'true');
        } else {
          entry.link.removeAttribute('aria-current');
        }
      });
    }

    updateActiveTableOfContents = function () {
      const scrollOffset = getSidebarScrollOffset(sectionRoot);
      let activeItem = orderedItems[0];

      orderedItems.forEach(function (entry) {
        const entryTop = entry.heading.getBoundingClientRect().top;

        if (entryTop - scrollOffset <= 0) {
          activeItem = entry;
        }
      });

      if (activeItem) {
        setActiveTableOfContentsItem(activeItem.id);
      }
    };

    updateActiveTableOfContents();
  }

  window.addEventListener('scroll', function () {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

    if (progressBarContainer) {
      if (scrollTop > lastScrollTop) {
        progressBarContainer.style.height = '7px';
      } else {
        progressBarContainer.style.height = '0';
      }
    }

    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
    updateProgressBar();

    if (typeof updateActiveTableOfContents === 'function') {
      updateActiveTableOfContents();
    }
  });

  initializeSidebarTableOfContents();
  updateProgressBar();
</script>

