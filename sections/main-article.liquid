{{ 'bm-blog-styles.css' | asset_url | stylesheet_tag }}
{{ 'section-blog-post.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    margin-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px !important;
    margin-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px !important;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      margin-top: {{ section.settings.padding_top }}px !important;
      margin-bottom: {{ section.settings.padding_bottom }}px !important;
    }
  }

  /* Featured image — mobile: full-bleed, vertical center crop */
  .article-template__hero-container {
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    width: 100vw;
    max-width: 100vw;
    overflow: hidden;
  }

  .article-template__hero-cover {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .article-template__hero-cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  /* Desktop: centered hero, constrained to 1080px */
  @media screen and (min-width: 750px) {
    .article-template__hero-container {
      position: relative;
      left: auto;
      right: auto;
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      max-width: 1080px;
      overflow: hidden;
      text-align: initial;
    }

    .article-template__hero-cover {
      display: block;
      width: 100%;
      aspect-ratio: auto;
      min-height: 450px;
      overflow: hidden;
      margin-left: auto;
      margin-right: auto;
    }

    .article-template__hero-cover img {
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
      object-fit: cover;
      object-position: center center;
    }
  }

  /* Header and content row constrained to 1080px */
  .c-article > .c-container > .c-article__header,
  .c-article > .c-container > .c-article__title,
  .c-article > .c-container > .article_date_box {
    max-width: 1080px;
    margin-left: auto;
    margin-right: auto;
  }

  .c-article__header {
    margin-bottom: 36px;
  }

  .c-article__breadcrumb {
    align-items: center;
    color: #9b968f;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 42px;
  }

  .c-article__breadcrumb a,
  .c-article__breadcrumb span {
    color: inherit;
    text-decoration: none;
  }

  .c-article__breadcrumb a:hover {
    text-decoration: underline;
  }

  .c-article__header-meta {
    align-items: center;
    color: #4d4943;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 20px;
    line-height: 1.4;
    margin-bottom: 20px;
  }

  .c-article__header-tag,
  .c-article__header-tag a {
    color: #34312d;
    text-decoration: none;
  }

  .c-article__header-tag {
    align-items: center;
    border: 1px solid #e8a94a;
    border-radius: 999px;
    display: inline-flex;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    min-height: 34px;
    padding: 8px 14px;
    text-transform: uppercase;
  }

  .c-article__header-tag a {
    color: inherit;
  }

  .c-article__header-tag--accent {
    color: #fff;
  }

  .c-article__header-tag a:hover {
    text-decoration: underline;
  }

  .c-article__header-separator {
    color: #7d776f;
  }

  .c-article__header .c-article__title {
    margin: 0;
    max-width: 820px;
  }

  .c-article__header-divider {
    border-top: 1px solid #e2c979;
    margin-top: 28px;
    padding-top: 18px;
  }

  .c-article__header-updated {
    color: #7d776f;
    font-size: 16px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .c-article__header {
      margin-bottom: 28px;
    }

    .c-article__breadcrumb {
      gap: 8px;
      margin-bottom: 28px;
    }

    .c-article__header-meta {
      font-size: 16px;
      gap: 8px;
      margin-bottom: 16px;
    }

    .c-article__header-divider {
      margin-top: 22px;
      padding-top: 14px;
    }
  }

  .c-article__body-row {
    display: flex;
    flex-direction: column;
    gap: 28px;
    max-width: 1080px;
    margin-left: auto;
    margin-right: auto;
  }

  .c-article__body-row--full {
    display: block;
  }

  .c-article__body-main {
    min-width: 0;
    width: 100%;
  }

  .c-article__body-main h2[id],
  .c-article__body-main h3[id],
  .c-article__body-main h4[id],
  .c-article__body-main h5[id],
  .c-article__body-main h6[id] {
    scroll-margin-top: calc(var(--article-sidebar-sticky-offset, 96px) + 28px);
  }

  .c-article__sidebar {
    order: -1;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .c-article__sidebar-card {
    background: #ffffff;
    border-radius: 3px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05);
    padding: 24px;
  }

  .c-article__sidebar-card > *:first-child {
    margin-top: 0;
  }

  .c-article__sidebar-card > *:last-child {
    margin-bottom: 0;
  }

  .c-article__sidebar-card .c-rte > *:first-child {
    margin-top: 0;
  }

  .c-article__sidebar-card .c-rte > *:last-child {
    margin-bottom: 0;
  }

  .c-article__sidebar-card img {
    max-width: 100%;
    height: auto;
  }

  .c-article__sidebar-card--toc .c-rte a {
    color: #4a4137;
    display: inline-block;
    padding-right: 32px;
    position: relative;
    text-decoration: none;
    transition: color 0.2s ease, font-weight 0.2s ease;
  }

  .c-article__sidebar-card--toc .c-rte a::after {
    content: '';
    display: block;
    height: 25px;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 25px;
  }

  .c-article__sidebar-card--toc .c-rte ul,
  .c-article__sidebar-card--toc .c-rte ol {
    list-style: none;
    margin: 0;
    padding-left: 0;
  }

  .c-article__sidebar-card--toc .c-rte li,
  .c-article__sidebar-card--toc .c-rte p {
    line-height: 1.55;
    margin: 0 0 12px;
  }

  .c-article__sidebar-card--toc .c-rte li:last-child,
  .c-article__sidebar-card--toc .c-rte p:last-child {
    margin-bottom: 0;
  }

  .c-article__sidebar-card--toc .c-rte a:hover,
  .c-article__sidebar-card--toc .c-rte a:focus-visible,
  .c-article__sidebar-card--toc .c-rte a.is-active {
    color: #f3b31f;
  }

  .c-article__sidebar-card--toc .c-rte a.is-active {
    font-weight: 500;
  }

  .c-article__sidebar-card--toc .c-rte a.is-active::after {
    background-image: url('https://cdn.shopify.com/s/files/1/0730/0608/8505/files/honey-bee-50.png');
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
  }

  .c-article__sidebar-block__title,
  .c-article__product-block__title {
    color: #333;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    margin: 0 0 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid #e8a94a;
  }

  .c-article__promo-card {
    background: #f3b31f;
    border-radius: 6px;
    display: block;
    overflow: hidden;
    padding: 14px;
  }

  .c-article__promo-card > *:last-child {
    margin-bottom: 0;
  }

  .c-article__promo-media {
    border-radius: 6px;
    display: block;
    margin-bottom: 16px;
    overflow: hidden;
  }

  .c-article__promo-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  .c-article__promo-body {
    align-items: center;
    display: grid;
    gap: 14px;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .c-article__promo-heading {
    color: var(--promo-text-color, #2f2b26);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
  }

  .c-article__promo-button {
    align-items: center;
    background: transparent;
    border: 1.5px solid var(--promo-button-border-color, #2f2b26);
    border-radius: 999px;
    color: var(--promo-button-text-color, #2f2b26);
    display: inline-flex;
    font-size: 14px;
    font-weight: 700;
    justify-content: center;
    line-height: 1.1;
    min-height: 52px;
    min-width: 144px;
    padding: 10px 18px;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .c-article__promo-button:hover {
    filter: brightness(0.96);
  }

  @media screen and (max-width: 989px) {
    .c-article__promo-card {
      display: none;
    }
  }

  @media screen and (max-width: 420px) {
    .c-article__promo-body {
      grid-template-columns: 1fr;
    }

    .c-article__promo-button {
      width: 100%;
    }
  }

  .c-article__product-card {
    display: grid;
    grid-template-columns: 92px minmax(0, 1fr);
    overflow: hidden;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
  }

  .c-article__product-card--no-image {
    display: block;
  }

  .c-article__product-image {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #c7beb7;
    min-height: 92px;
    padding: 6px;
    overflow: hidden;
  }

  .c-article__product-image img {
    display: block;
    width: 100%;
    max-width: 100%;
    max-height: 82px;
    height: auto;
    object-fit: contain;
    transform: scale(1.04);
    transition: transform 0.25s ease;
  }

  .c-article__product-content {
    min-width: 0;
    padding: 14px 14px 12px;
  }

  .c-article__product-reviews {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 5px;
    color: #555;
    font-size: 12px;
    line-height: 1.2;
    margin-bottom: 8px;
  }

  .c-article__product-stars {
    color: #f4b321;
    font-size: 16px;
    letter-spacing: 1px;
  }
  .c-article__product-scores {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 12px;
  }

  .c-article__product-score {
    background: #fff;
    border: 1px solid #e8a94a;
    border-radius: 20px;
    color: #333;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    min-height: 30px;
    padding: 7px 12px;
  }

  .c-article__product-score--accent {
    color: #fff;
  }

  .c-article__product-description {
    color: #555;
    font-size: 12px;
    line-height: 1.35;
    margin-bottom: 12px;
  }

  .c-article__product-description > * {
    margin-top: 0;
    margin-bottom: 0;
  }

  .c-article__product-description p {
    margin: 0;
  }

  .c-article__product-button {
    align-items: center;
    background: #f3b31f;
    border-radius: 20px;
    color: #333;
    display: inline-flex;
    font-size: 13px;
    font-weight: 700;
    justify-content: center;
    line-height: 1;
    min-height: 34px;
    padding: 10px 22px;
    text-decoration: none;
    text-transform: uppercase;
  }

  .c-article__product-button:hover {
    background: #e8a94a;
    color: #333;
  }

  @media screen and (min-width: 750px) {
    .c-article__product-card {
      grid-template-columns: minmax(128px, 42%) minmax(0, 1fr);
    }

    .c-article__product-image {
      min-height: 190px;
      padding: 0;
    }

    .c-article__product-image img {
      width: 100%;
      height: 100%;
      max-height: none;
      object-fit: cover;
      transform: scale(1.1);
    }

    .c-article__product-content {
      padding: 18px 18px 16px;
    }
  }

  @media screen and (min-width: 990px) {
    .c-article__body-row {
      display: grid;
      grid-template-columns: minmax(260px, 3fr) minmax(0, 7fr);
      gap: 32px;
      align-items: start;
    }

    .c-article__body-row--full {
      display: block;
    }

    .c-article__sidebar {
      order: initial;
      position: sticky;
      top: var(--article-sidebar-sticky-offset, 96px);
    }

    .c-article__body-main {
      grid-column: 2;
    }

    .c-article__sidebar {
      grid-column: 1;
      grid-row: 1;
    }
  }

  /* Reading progress bar */
  .progress-bar-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 0;
    background-color: #f3f3f3;
    z-index: 9999;
  }

  .progress-bar {
    height: 100%;
    width: 0;
    background-image: linear-gradient(90deg, #ee005c, #2b38f6);
    transition: width 0.1s ease;
    display: block;
  }

  /* Hide Honey extension overlays */
  .hideExisting_Honey,
  .nzHoney_overlaysPopup {
    display: none !important;
  }

  /* Date / tag box (from Code 1) */
  .article_date_box {
    margin-top: 10px;
    font-size: 15px;
    color: #222;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    padding: 20px 0px;
  }

  @media (min-width: 768px) {
    .article_date_box {
      flex-direction: row;
      align-items: center;
      gap: 20px;
    }
  }

  .c-article__meta__published,
  .c-article__meta__updated {
    font-size: 16px;
    color: #999;
    letter-spacing: 1px;
    text-transform: capitalize;
    line-height: 18px;
  }

  .c-article__meta__tag {
    background: #e86c1c;
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    padding: 8px 20px;
    border-radius: 20px;
    text-transform: uppercase;
    width: fit-content;
  }

  .c-article__meta__tag a {
    color: #fff;
    text-decoration: none;
  }

  .c-article__meta__tag a:hover {
    text-decoration: underline;
  }

  @media (max-width: 765px) {
    .c-article__meta__tag {
      margin-top: 10px;
    }
  }
{%- endstyle -%}

{% if request.path contains '/manuka-honey-umf-certification/' %}
  <style>
    body.body_article .c-article__body-row {
      max-width: 1250px;
      margin-left: auto;
      margin-right: auto;
    }
  </style>
{% endif %}

{%- liquid
  assign article_sidebar_content_enabled = true
  assign article_sidebar_product_enabled = true
  assign article_sidebar_key = section.settings.sidebar_metafield_key | default: 'article_sidebar'
  assign article_sidebar_product_key = section.settings.sidebar_product_metafield_key | default: 'article_sidebar_product'
  assign article_sidebar_title = section.settings.sidebar_content_title | strip
  assign article_sidebar_product_title = section.settings.sidebar_product_title | strip
  assign article_sidebar_promo_heading = section.settings.sidebar_promo_heading | strip
  assign article_sidebar_promo_button_label = section.settings.sidebar_promo_button_label | strip
  assign article_sidebar_promo_button_link = section.settings.sidebar_promo_button_link
  assign article_sidebar_promo_position = section.settings.sidebar_promo_position | default: 'above_toc'
  assign article_sidebar_promo_background = section.settings.sidebar_promo_background
  assign article_sidebar_promo_text_color = section.settings.sidebar_promo_text_color
  assign article_sidebar_promo_button_text_color = section.settings.sidebar_promo_button_text_color
  assign article_sidebar_promo_button_border_color = section.settings.sidebar_promo_button_border_color
  assign article_sidebar_promo_image = section.settings.sidebar_promo_image
  assign article_sidebar_promo_image_alt = article_sidebar_promo_heading
  assign article_primary_tag = article.tags | first
  assign show_article_published = true
  assign show_article_updated = true
  assign show_article_tag = false
  assign show_article_header_meta = false
  assign article_sidebar_promo_enabled = false
  assign article_sidebar_content = article.metafields.custom.article_sidebar

  if article.tags != blank
    assign show_article_tag = true
  endif

  if section.settings.enable_sidebar_content == false
    assign article_sidebar_content_enabled = false
  endif

  if section.settings.enable_sidebar_product == false
    assign article_sidebar_product_enabled = false
  endif

  if article_sidebar_promo_image != blank and article_sidebar_promo_image.alt != blank
    assign article_sidebar_promo_image_alt = article_sidebar_promo_image.alt
  endif

  for block in section.blocks
    if block.type == 'meta'
      assign show_article_published = block.settings.show_published
      assign show_article_updated = block.settings.show_updated
      assign show_article_tag = block.settings.show_tag
      break
    endif
  endfor

  if article_sidebar_content == blank
    assign article_sidebar_content = blog.metafields.custom.article_sidebar
  endif

  if show_article_tag and article_primary_tag != blank
    assign show_article_header_meta = true
  endif

  if show_article_published
    assign show_article_header_meta = true
  endif

  if article_sidebar_content == blank
    assign article_sidebar_content = article.metafields.custom[article_sidebar_key]
  endif

  if article_sidebar_content == blank
    assign article_sidebar_content = blog.metafields.custom[article_sidebar_key]
  endif

  if article_sidebar_content == blank
    assign article_sidebar_content = article.metafields.custom.sidebar_content
  endif

  if article_sidebar_content == blank
    assign article_sidebar_content = blog.metafields.custom.sidebar_content
  endif

  if article_sidebar_content == blank
    assign article_sidebar_content = article.metafields.custom.static_block
  endif

  if article_sidebar_content == blank
    assign article_sidebar_content = blog.metafields.custom.static_block
  endif

  assign article_sidebar_product_source = article.metafields.custom[article_sidebar_product_key]

  if article_sidebar_product_source == blank
    assign article_sidebar_product_source = article.metafields.custom.article_sidebar_product
  endif

  if article_sidebar_product_source == blank
    assign article_sidebar_product_source = article.metafields.custom.sidebar_product
  endif

  if article_sidebar_product_source == blank
    assign article_sidebar_product_source = article.metafields.custom.product_id
  endif

  if article_sidebar_product_source == blank
    assign article_sidebar_product_source = article.metafields.custom.product_handle
  endif

  if article_sidebar_product_source != blank
    if article_sidebar_product_source.type contains 'product_reference'
      assign article_sidebar_product = article_sidebar_product_source.value

      if article_sidebar_product.title == blank
        assign article_sidebar_product = article_sidebar_product_source.value | first
      endif
    else
      assign article_sidebar_product_lookup = article_sidebar_product_source.value | default: article_sidebar_product_source | strip
      assign article_sidebar_product_lookup = article_sidebar_product_lookup | split: '/products/' | last | split: '?' | first | split: '#' | first | split: '/' | first | handleize
      assign article_sidebar_product = all_products[article_sidebar_product_lookup]
    endif
  endif

  assign article_sidebar_has_content = false

  if section.settings.enable_sidebar_promo and article_sidebar_promo_heading != blank
    assign article_sidebar_promo_enabled = true
  endif

  if section.settings.enable_sidebar_promo and article_sidebar_promo_image != blank
    assign article_sidebar_promo_enabled = true
  endif

  if section.settings.enable_sidebar_promo and article_sidebar_promo_button_label != blank
    assign article_sidebar_promo_enabled = true
  endif

  if article_sidebar_content_enabled and article_sidebar_content != blank
    assign article_sidebar_has_content = true
  endif

  if article_sidebar_product_enabled and article_sidebar_product != blank
    assign article_sidebar_has_content = true
  endif

  if article_sidebar_promo_enabled
    assign article_sidebar_has_content = true
  endif

  if article_sidebar_product != blank
    assign sidebar_product_umf_score = article_sidebar_product.metafields.custom.umf_score.value | default: article_sidebar_product.metafields.custom.umf_score
    assign sidebar_product_mgo_score = article_sidebar_product.metafields.custom.mgo_score.value | default: article_sidebar_product.metafields.custom.mgo_score
    assign sidebar_product_badge_color = article_sidebar_product.metafields.custom.color.value | default: article_sidebar_product.metafields.custom.color
    assign sidebar_product_short_description = article_sidebar_product.metafields.custom.collection_short_description
    assign sidebar_product_review_average = article_sidebar_product.metafields.stamped.reviews_average
    assign sidebar_product_review_count = article_sidebar_product.metafields.stamped.reviews_count

    if sidebar_product_review_average == blank
      assign sidebar_product_review_average = article_sidebar_product.metafields.reviews.rating.value.rating
    endif

    if sidebar_product_review_average == blank
      assign sidebar_product_review_average = article_sidebar_product.metafields.reviews.rating.value
    endif

    if sidebar_product_review_count == blank
      assign sidebar_product_review_count = article_sidebar_product.metafields.reviews.rating_count.value
    endif
  endif
-%}

{%- capture article_sidebar_promo_markup -%}
  {%- if article_sidebar_promo_enabled -%}
    <div
      class="c-article__promo-card"
      style="
        {% if article_sidebar_promo_background != blank %}background-color: {{ article_sidebar_promo_background | escape }};{% endif %}
        {% if article_sidebar_promo_text_color != blank %}--promo-text-color: {{ article_sidebar_promo_text_color | escape }};{% endif %}
        {% if article_sidebar_promo_button_text_color != blank %}--promo-button-text-color: {{ article_sidebar_promo_button_text_color | escape }};{% endif %}
        {% if article_sidebar_promo_button_border_color != blank %}--promo-button-border-color: {{ article_sidebar_promo_button_border_color | escape }};{% endif %}
      "
    >
      {%- if article_sidebar_promo_image != blank -%}
        {%- if article_sidebar_promo_button_link != blank -%}
          <a class="c-article__promo-media" href="{{ article_sidebar_promo_button_link }}">
            {{
              article_sidebar_promo_image
              | image_url: width: 720
              | image_tag:
                loading: 'lazy',
                widths: '360, 540, 720',
                alt: article_sidebar_promo_image_alt
            }}
          </a>
        {%- else -%}
          <div class="c-article__promo-media">
            {{
              article_sidebar_promo_image
              | image_url: width: 720
              | image_tag:
                loading: 'lazy',
