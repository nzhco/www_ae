      {%- if article_sidebar_promo_enabled and article_sidebar_promo_position == 'above_toc' -%}
        {{ article_sidebar_promo_markup }}
      {%- endif -%}

      {%- if article_sidebar_content_enabled and article_sidebar_content != blank -%}
        <div class="c-article__sidebar-card" data-sidebar-content-card>
          {%- if article_sidebar_title != blank -%}
            <h3 class="c-article__sidebar-block__title">{{ article_sidebar_title | escape }}</h3>
          {%- endif -%}

          <div class="c-rte" data-sidebar-content>
            {%- if article_sidebar_content.type != blank -%}
              {{ article_sidebar_content | metafield_tag }}
            {%- else -%}
              {{ article_sidebar_content }}
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if article_sidebar_product_enabled and article_sidebar_product != blank -%}
        <div class="c-article__product-block">
          {%- if article_sidebar_product_title != blank -%}
            <h3 class="c-article__product-block__title">{{ article_sidebar_product_title | escape }}</h3>
          {%- endif -%}
          <div class="c-article__product-card{% if article_sidebar_product.featured_image == blank %} c-article__product-card--no-image{% endif %}">
