{% comment %}theme-check-disable UndefinedObject{% endcomment %}

{%- style -%}
.nzhc-footer {
  background: {{ section.settings.bg_color }};
  color: #fbf9f6 !important;
  font-family: 'GT Walsheim Pro', system-ui, sans-serif;
  font-size: 18px !important;
  font-weight: 500;
  line-height: 22px;
}

.footer-authority {
  text-align: center;
  padding: 18px;
  font-size: 18px !important;
  font-weight: 500;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  color: #fbf9f6 !important;
  line-height: 22px;
  background: linear-gradient( 120deg, #ff4a00, #f73c64 30%, #d32f5d 60%, #1fa2ff );
}

.footer-container {
  max-width: 1400px;
  margin: auto;
  padding: 70px 40px;
  display: grid;
  grid-template-columns: 1.2fr 1.1fr 1.2fr 1.3fr;
  gap: 60px;
}

.footer-title {
  font-size: 18px !important;
  font-weight: 400;
  letter-spacing: .15em;
  margin-bottom: 20px;
  text-transform: uppercase;
  color: #fbf9f6 !important;
  line-height: 22px;
}

.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.footer-col li {
  margin: 10px 0;
  font-size: 18px !important;
  font-weight: 400;
  color: #fbf9f6 !important;
  line-height: 22px;
}

.footer-col a {
  color: #fbf9f6 !important;
  text-decoration: none;
  font-size: 18px !important;
  font-weight: 500;
  line-height: 22px;
}

.footer-col a:hover {
  color: #fbf9f6 !important;
}

.footer-logo {
  width: {{ section.settings.logo_width }}px;
  margin-bottom: 20px;
  display: block;
}

.footer-logo-link {
  display: inline-block;
}

.footer-rewards {
  font-size: 18px !important;
  font-weight: 400;
  margin-bottom: 10px;
  color: #fbf9f6 !important;
  line-height: 22px;
}

.footer-rewards a {
  color: #fbf9f6 !important;
  text-decoration: none;
  font-size: 18px !important;
  font-weight: 400;
  line-height: 22px;
}

.footer-rewards a:hover {
  text-decoration: underline;
}

.footer-social {
  display: flex;
  gap: 18px;
  margin-top: 10px;
}

.footer-social img {
  width: {{ section.settings.social_icon_size }}px;
  height: {{ section.settings.social_icon_size }}px;
  opacity: .8;
  transition: all .25s ease;
}

.footer-social a:hover img {
  opacity: 1;
  transform: scale(1.15);
}

.footer-legal {
  border-top: 1px solid rgba(255,255,255,0.1);
  text-align: center;
  padding: 40px 20px;
}

.footer-links {
  display: flex;
  justify-content: center;
  gap: 25px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}

.footer-links a {
  color: #fbf9f6 !important;
  font-size: 14px !important;
  font-weight: 400;
  text-decoration: none;
  line-height: 22px;
}

.footer-links a:hover {
  text-decoration: underline;
}

.footer-payments {
  display: flex;
  justify-content: center;
  gap: 10px;
  flex-wrap: wrap;
  margin: 20px 0;
}

.footer-payments img {
  height: 30px;
}

.footer-disclaimer {
  max-width: 700px;
  margin: auto;
  font-size: 14px !important;
  color: #fbf9f6 !important;
  line-height: 1.6;
  font-weight:400;
}

.copyright {
  margin: 22px 0;
  font-size: 14px !important;
  color: #fbf9f6 !important;
  line-height: 22px;
  font-weight:400;
}

@media (max-width: 768px) {
  .footer-container {
    grid-template-columns: 1fr;
    gap: 35px;
    padding: 50px 25px;
  }

  .footer-title {
    border-bottom: 1px solid rgba(255,255,255,.1);
    padding-bottom: 8px;
  }
}
{%- endstyle -%}

<footer class="nzhc-footer">

  {%- if section.settings.authority_text != blank -%}
    <div class="footer-authority">
      {{ section.settings.authority_text }}
    </div>
  {%- endif -%}

  <div class="footer-container">

    {%- comment -%} Brand Column {%- endcomment -%}
    <div class="footer-col brand">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="footer-logo-link" aria-label="{{ shop.name | escape }}">

        <img
          src="{{ section.settings.logo | image_url: width: 560 }}"
          class="footer-logo"
          alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
          loading="lazy"
          width="{{ section.settings.logo_width }}"
        >

        </a>
      {%- endif -%}

      {%- if section.settings.rewards_text != blank -%}
        <p class="footer-rewards">
          {%- if section.settings.rewards_link != blank -%}
            <a href="{{ section.settings.rewards_link }}">{{ section.settings.rewards_text }}</a>
          {%- else -%}
            {{ section.settings.rewards_text }}
          {%- endif -%}
        </p>
      {%- endif -%}

      <div class="footer-social">
        {%- for block in section.blocks -%}
          {%- if block.type == 'social_icon' -%}
            <a href="{{ block.settings.social_link }}" aria-label="{{ block.settings.social_label | escape }}" {{ block.shopify_attributes }}>
              {%- if block.settings.social_image != blank -%}
                <img
                  src="{{ block.settings.social_image | image_url: width: 100 }}"
                  alt="{{ block.settings.social_label | escape }}"
                  loading="lazy"
                >
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Menu Columns {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu_column' -%}
        <div class="footer-col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h4 class="footer-title">{{ block.settings.heading }}</h4>
          {%- endif -%}

          {%- if block.settings.menu != blank -%}
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}">{{ link.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Support / Text Column {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'text_column' -%}
        <div class="footer-col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h4 class="footer-title">{{ block.settings.heading }}</h4>
          {%- endif -%}

          {%- if block.settings.richtext != blank -%}
            <ul>
              {{ block.settings.richtext }}
            </ul>
          {%- endif -%}

          {%- if block.settings.menu != blank -%}
            <ul>
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}">{{ link.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>

  {%- comment -%} Legal Section {%- endcomment -%}
  <div class="footer-legal">

    {%- if section.settings.show_policy -%}
      <div class="footer-links">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
          {%- endif -%}
        {%- endfor -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'legal_link' -%}
            <a href="{{ block.settings.link_url }}" {{ block.shopify_attributes }}>{{ block.settings.link_text }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.payment_enable -%}
      <div class="footer-payments">
        {%- for block in section.blocks -%}
          {%- if block.type == 'payment_icon' -%}
            {%- if block.settings.payment_image != blank -%}
              <img
                src="{{ block.settings.payment_image | image_url: width: 100 }}"
                alt="{{ block.settings.payment_label | escape }}"
                loading="lazy"
                {{ block.shopify_attributes }}
              >
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.copyright_text != blank -%}
      <p class="copyright">{{ section.settings.copyright_text }}</p>
    {%- endif -%}

    {%- if section.settings.disclaimer_text != blank -%}
      <p class="footer-disclaimer">{{ section.settings.disclaimer_text }}</p>
    {%- endif -%}

  </div>

</footer>

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2e2e2e"
    },
    {
      "type": "text",
      "id": "authority_text",
      "label": "Authority Line Text",
      "default": "Premium UMF™ Certified Manuka Honey. Harvested and packed in New Zealand."
    },
    {
      "type": "header",
      "content": "Brand Column"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 180
    },
    {
      "type": "text",
      "id": "rewards_text",
      "label": "Rewards Text",
      "default": "Join Colourclub Rewards"
    },
    {
      "type": "url",
      "id": "rewards_link",
      "label": "Rewards Link"
    },
    {
      "type": "range",
      "id": "social_icon_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Social Icon Size",
      "default": 22
    },
    {
      "type": "header",
      "content": "Legal Section"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "Show Policy Links"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Show Payment Icons"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© New Zealand Honey Co. All rights reserved."
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "FDA Disclaimer: These statements have not been evaluated by the Food and Drug Administration. This product is not intended to diagnose, treat, cure, or prevent any disease."
    }
  ],
  "blocks": [
    {
      "type": "social_icon",
      "name": "Social Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "social_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "social_label",
          "label": "Label (for accessibility)",
          "default": "Social"
        },
        {
          "type": "url",
          "id": "social_link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "menu_column",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SHOP"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text_column",
      "name": "Text + Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SUPPORT"
        },
        {
          "type": "richtext",
          "id": "richtext",
          "label": "Text Content (phone numbers, etc.)"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu (links below text)"
        }
      ]
    },
    {
      "type": "legal_link",
      "name": "Extra Legal Link",
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Accessibility Statement"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "payment_icon",
      "name": "Payment Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "payment_image",
          "label": "Payment Icon Image"
        },
        {
          "type": "text",
          "id": "payment_label",
          "label": "Label (for accessibility)",
          "default": "Visa"
        }
      ]
    }
  ],
  "default": {
    "settings": {},
    "blocks": [
      {
        "type": "menu_column",
        "settings": {
          "heading": "SHOP"
        }
      },
      {
        "type": "menu_column",
        "settings": {
          "heading": "LEARN"
        }
      },
      {
        "type": "text_column",
        "settings": {
          "heading": "SUPPORT"
        }
      }
    ]
  }
}
{% endschema %}
