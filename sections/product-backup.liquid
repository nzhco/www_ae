<script>
  var productObject = {{ product | json }};

  // Function to update the variant selection
  function updateVariantSelection(element) {
    var variantId = element.getAttribute('data-id');
    var variantName = element.getAttribute('data-value');
    document.getElementById('Option1--variant_picker').value = variantId;
    document.getElementById('variant-name-display').textContent = variantName;
    document.querySelector('.product-form__option-element.selected')?.classList.remove('selected');
    element.classList.add('selected');

    // Update ReCharge subscription details
    updateReCharge(variantId);
  }

  // Function to handle ReCharge updates
  function updateReCharge(variantId) {
    var event = new CustomEvent('variantChange', { detail: { variantId: variantId } });
    document.dispatchEvent(event);

    // Simulating a change event for ReCharge
    var selectElement = document.getElementById('Option1--variant_picker');
    if ("createEvent" in document) {
      var evt = document.createEvent("HTMLEvents");
      evt.initEvent("change", false, true);
      selectElement.dispatchEvent(evt);
    } else {
      selectElement.fireEvent("onchange");
    }
  }

  // Select the first variant on page load
  document.addEventListener("DOMContentLoaded", function () {
    var firstVariantElement = document.querySelector('.product-form__option-element');
    if (firstVariantElement) {
      updateVariantSelection(firstVariantElement);
    }
  });
</script>

