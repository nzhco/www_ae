<script>
  var productObject = {{ product | json }}
</script>
<script src="{{ 'jarallax.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'jarallax-video.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'fancybox.umd.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'ScrollTrigger.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-variant-swatches.js' | asset_url }}" defer="defer"></script>
{{ 'fancybox.css' | asset_url | stylesheet_tag }}
{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
{{ 'product.css' | asset_url | stylesheet_tag }}
{{ 'stamped-main.css' | asset_url | stylesheet_tag }}
{{ 'sale-badge.css' | asset_url | stylesheet_tag }}
<div
  class="c-container"
  {% if product.metafields.custom.color != blank %}
    style="--product-color: {{ product.metafields.custom.color | escape }};"
  {% endif %}
>
  {%- assign featured_media = product.selected_or_first_available_variant.featured_image
    | default: product.featured_image
  -%}

  {% liquid
    assign default_variant_id = null
    assign show_class = ''
    assign product_color = '#f1b434'

    if product.metafields.custom.color != blank
      assign product_color = product.metafields.custom.color
    endif

    if product.variants != blank
      for variant in product.variants
        if settings.default_variants contains variant.title
          assign default_variant_id = variant.id
        endif
        if variant.selected == true
          assign default_variant_id = variant.id
        endif
      endfor
      if default_variant_id == null
        for variant in product.variants
          if variant == product.selected_or_first_available_variant
            assign default_variant_id = variant.id
          endif
        endfor
      endif
    endif
  %}
  {% if section.settings.dropdown %}
    {{ 'variant-swatches.css' | asset_url | stylesheet_tag }}

  {% endif %}

  <div class="c-product__content  sss" data-product-color="{{ product_color }}">
    <div class="c-product__left">
      {%- if featured_media != null -%}
        <div class="c-product__slider swiper">
          <div class="c-product__slider__wrapper swiper-wrapper">
            {%- if featured_media != null -%}
              <div class="c-product__image swiper-slide">
                <div class="c-product__image__wrapper u-absolute-fill{% if product.selected_or_first_available_variant.id != blank and product.variants.size > 1 %} show-variant{% endif %}">
                  <div class="c-product__image__main u-absolute-fill">
                    <a
                      data-id="{{ featured_media.id }}"
                      data-fancybox="gallery"
                      data-src="{{ featured_media | image_url: width: 1600 }}"
                      class="c-product__image__featured u-absolute-fill"
                    >
                      {{
                        featured_media
                        | image_url: width: featured_media.width
                        | image_tag:
                          height: featured_media.height,
                          alt: featured_media.alt,
                          class: 'u-absolute-fill',
                          loading: 'lazy'
                      }}
                    </a>
                  </div>
                  {%- if product.variants != blank -%}
                    <div class="c-product__image__variants u-absolute-fill">
                      {%- for variant in product.variants -%}
                        {% liquid
                          if product.selected_or_first_available_variant == variant
                            assign show_class = 'u-absolute-fill c-product__image__variant show-variant-image'
                          else
                            assign show_class = 'u-absolute-fill c-product__image__variant'
                          endif
                        %}
                        {%- if variant.featured_media != blank -%}
                          <a
                            data-id="{{ variant.featured_media.id }}"
                            data-fancybox="gallery"
                            data-src="{{ variant.featured_media | image_url: width: 1600 }}"
                            class="{{ show_class }}"
                            data-variant-id="{{ variant.id }}"
                          >
                            {{
                              variant.featured_media
                              | image_url: width: variant.featured_media.width
                              | image_tag:
                                height: variant.featured_media.height,
                                alt: variant.featured_media.alt,
                                class: 'u-absolute-fill',
                                loading: 'lazy'
                            }}
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
                {%- if product.metafields.custom.background_image != blank -%}
                  {{
                    product.metafields.custom.background_image
                    | image_url: width: product.metafields.custom.background_image.width
                    | image_tag:
                      height: product.metafields.custom.background_image.height,
                      alt: product.metafields.custom.background_image.alt,
                      class: 'c-product__image__background',
                      loading: 'lazy'
                  }}
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if product.media.size > 1 -%}
              {%- for media in product.media -%}
                {%- unless media.id == product.selected_or_first_available_variant.featured_media.id
                  or media.alt contains 'variant'
                -%}
                  <div class="swiper-slide c-product__slider__item">
                    <a
                      data-id="{{ media.id }}"
                      data-fancybox="gallery"
                      data-src="{% if media.media_type == 'image' %}{{ media | image_url: width: 1600 }}{% else if media.media_type == "external_video" %}{% if media.host == 'youtube' %}https://www.youtube.com/watch?v={% else %}https://vimeo.com/{% endif %}{{ media.external_id }}{% endif %}"
                      class="c-product__gallery__item{% if media.media_type == "external_video" %} jarallax jarallax-mobile{% endif %}"
                    >
                      {% if media.media_type == 'external_video' %}
                        <div class="c-product__gallery__icon">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <polygon points="5 3 19 12 5 21 5 3"></polygon>
                          </svg>
                        </div>
                      {% else %}
                        <div class="c-product__gallery__icon is-zoom">
                          <svg
                            viewBox="0 0 24 24"
                            width="24"
                            height="24"
                            stroke="currentColor"
                            stroke-width="2"
                            fill="none"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="css-i6dzq1"
                          >
                            <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </div>
                      {% endif %}
                      {% if media.media_type == 'external_video' %}
                        {{
                          media
                          | image_url: width: media.width
                          | image_tag:
                            height: media.height,
                            alt: media.alt,
                            class: 'c-product__gallery__img jarallax-img',
                            loading: 'lazy'
                        }}
                      {% else %}
                        {{
                          media
                          | image_url: width: media.width
                          | image_tag:
                            height: media.height,
                            alt: media.alt,
                            class: 'c-product__gallery__img',
                            loading: 'lazy'
                        }}
                      {% endif %}
                    </a>
                  </div>
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
          <div class="c-product__slider__nav c-product__slider__nav--prev swiper-button-prev">
            {%- render 'icon-arrow', type: 'left' -%}
          </div>
          <div class="c-product__slider__nav c-product__slider__nav--next swiper-button-next">
            {%- render 'icon-arrow', type: 'right' -%}
          </div>
        </div>
      {%- endif -%}
      {%- if product.media.size > 1 -%}
        <div class="c-product__gallery">
          {%- for media in product.media -%}
            {%- unless media.id == product.selected_or_first_available_variant.featured_media.id
              or media.alt contains 'variant'
            -%}
              <a
                data-id="{{ media.id }}"
                data-fancybox="gallery"
                data-src="{% if media.media_type == 'image' %}{{ media | image_url: width: 1600 }}{% else if media.media_type == "external_video" %}{% if media.host == 'youtube' %}https://www.youtube.com/watch?v={% else %}https://vimeo.com/{% endif %}{{ media.external_id }}{% endif %}"
                class="c-product__gallery__item{% if media.media_type == "external_video" %} jarallax jarallax-desktop{% endif %}"
              >
                {% if media.media_type == 'external_video' %}
                  <div class="c-product__gallery__icon">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polygon points="5 3 19 12 5 21 5 3"></polygon>
                    </svg>
                  </div>
                {% endif %}
                {% if media.media_type == 'external_video' %}
                  {{
                    media
                    | image_url: width: media.width
                    | image_tag:
                      height: media.height,
                      alt: media.alt,
                      class: 'c-product__gallery__img jarallax-img',
                      loading: 'lazy'
                  }}
                {% else %}
                  {{
                    media
                    | image_url: width: media.width
                    | image_tag: height: media.height, alt: media.alt, class: 'c-product__gallery__img', loading: 'lazy'
                  }}
                {% endif %}
              </a>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
    <div class="c-product__right">
      <div class="c-product__info-top">
        <div class="c-product__title">
  {%- if product.metafields.custom.product_name != blank -%}
    <h1>
      {{ product.metafields.custom.product_name | escape }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
        </span>
      {%- endif -%}
      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- elsif product.title != blank -%}
    <h1>
      {{ product.title | escape }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
        </span>
      {%- endif -%}
      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- else -%}
    <h1>
      {{ 'sections.main_product.manuka_honey' | t }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
        </span>
      {%- endif -%}
      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- endif -%}
</div>
        {%- if product.description != blank or product.metafields.custom.short_description != blank -%}
          <div class="c-product__description rte">
            {% if section.settings.product_content == 'full' %}
              {{ product.description }}
            {% else %}
              {% if product.metafields.custom.tagline != blank %}
                <div class="c-product__tagline">
                  <p>
                    <strong>{{ product.metafields.custom.tagline }}</strong>
                  </p>
                  {%- if settings.public_api != blank -%}
                    <a
                      href="#stamped-main-widget"
                      class="c-product__rating c-product__rating--js c-product__rating--hidden"
                      data-rating="5"
                      data-public-api="{{ settings.public_api }}"
                      data-product-id="{{ product.id }}"
                      data-domain="{{ shop.domain }}"
                    >
                      <div class="c-product__rating__stars">
                        <span class="c-product__rating__star">
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                        </span>
                        <span class="c-product__rating__star--background">
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                          <svg
                            width="18"
                            height="16"
                            viewBox="0 0 18 16"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                          </svg>
                        </span>
                      </div>
                      <div class="c-product__rating__info"></div>
                    </a>
                  {%- else -%}
                    {%- if product.metafields.reviews.rating.value != blank -%}
                      {% liquid
                        assign rating_decimal = 0
                        assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                        if decimal >= 0.3 and decimal <= 0.7
                          assign rating_decimal = 0.5
                        elsif decimal > 0.7
                          assign rating_decimal = 1
                        endif
                      %}
                      <a href="#ratings" class="c-product__rating">
                        <div class="c-product__rating__stars">
                          <span
                            class="c-product__rating__star "
                            style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
                          >
                            <svg
                              width="18"
                              height="16"
                              viewBox="0 0 18 16"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                            </svg>
                            <svg
                              width="18"
                              height="16"
                              viewBox="0 0 18 16"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M16.6657 1.3918C14.8865 -0.463932 12.0118 -0.463932 10.2435 1.3918L8.86575 2.59123L7.75923 1.43706C5.98011 -0.41867 3.10532 -0.41867 1.3262 1.43706C-0.442067 3.28147 -0.442067 6.29137 1.3262 8.13578L8.86575 16L14.6696 9.94625L16.6657 7.86421C18.4448 6.00849 18.4448 3.24752 16.6657 1.3918Z" fill="#F1B434"/>
                            </svg>
                            <svg
                              width="18"
                              height="16"
                              viewBox="0 0 18 16"
                              fill="none"
