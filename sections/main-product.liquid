    {% if request.locale.iso_code contains 'en' %}
  <h2>Pure Monofloral</h2>
{% else %}
  <h2>أحادي الزهرة النقي</h2>
{% endif %}

  </div>
</section>
        <div class="c-product__title">
  {%- if product.metafields.custom.product_name != blank -%}
