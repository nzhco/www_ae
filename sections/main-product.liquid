<script>
document.addEventListener("DOMContentLoaded", function () {
    // Select all variant thumbnails
    const variantElements = document.querySelectorAll(".product-form__option-element");

    // Get the first variant price and display it
    if (variantElements.length > 0) {
        let firstVariantPrice = variantElements[0].getAttribute("data-price");
        document.getElementById("variant-price").innerText = "Dhs. " + firstVariantPrice;
    }

    // Add click event listener to each variant
    variantElements.forEach(element => {
        element.addEventListener("click", function () {
            // Get selected variant price
            let selectedPrice = this.getAttribute("data-price");

            // Update the price display
            document.getElementById("variant-price").innerText = "Dhs. " + selectedPrice;
        });
    });
});
</script>
