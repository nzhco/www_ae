      {{ product.metafields.custom.product_name | escape }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
