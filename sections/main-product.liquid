                      %}{{ i | times: 100 | divided_by: umf_counter }}%{% endif %}{% endfor %}
                  );
                }
              </style>
            </div>

            {%- if section.settings.scale_start != blank and section.settings.scale_end != blank -%}
              <div class="c-product__umf__slider__labels">
                <span>{{ section.settings.scale_start | escape }}</span>
                <span>{{ section.settings.scale_end | escape }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
  </div>
</div>

<script>
