      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- elsif product.title != blank -%}
