{{ 'consumberlab.css' | asset_url | stylesheet_tag }}
{% style %}
  #shopify-section-{{ section.id }} .c-product__offer-banner {
    margin-top: 18px;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__inner {
    background: {{ section.settings.subscription_offer_bg_color }};
    border-radius: {{ section.settings.subscription_offer_border_radius }}px;
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.14);
    color: {{ section.settings.subscription_offer_text_color }};
    margin: 0 auto;
    max-width: {{ section.settings.subscription_offer_max_width }}px;
    padding: 12px 18px;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__inner.is-clickable {
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__layout {
    align-items: center;
    display: flex;
    gap: 16px;
    justify-content: center;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__content {
    flex: 1 1 auto;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__title {
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__link {
    color: {{ section.settings.subscription_offer_link_color }};
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__caption {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.2;
    margin: 4px 0 0;
    opacity: 0.92;
  }

  #shopify-section-{{ section.id }} .c-product__offer-banner__cta {
    background: {{ section.settings.subscription_offer_cta_bg_color }};
    border-radius: 999px;
    color: {{ section.settings.subscription_offer_cta_text_color }};
    display: inline-flex;
    font-size: 12px;
    font-weight: 700;
    justify-content: center;
    line-height: 1;
    min-width: 120px;
    padding: 11px 16px;
    text-decoration: none;
    white-space: nowrap;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .c-product__offer-banner__inner {
      padding: 10px 14px;
    }

    #shopify-section-{{ section.id }} .c-product__offer-banner__layout {
      flex-direction: column;
      gap: 10px;
    }

    #shopify-section-{{ section.id }} .c-product__offer-banner__title {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .c-product__offer-banner__caption {
      font-size: 14px;
    }

    #shopify-section-{{ section.id }} .c-product__offer-banner__cta {
      min-width: 0;
      width: 100%;
    }
  }
{% endstyle %}
<div
  class="c-container"
  {% if product.metafields.custom.color != blank %}
    style="--product-color: {{ product.metafields.custom.color | escape }};"
  {% endif %}
>
  {%- assign featured_media = product.selected_or_first_available_variant.featured_image
    | default: product.featured_image
  -%}

  {% liquid
    assign default_variant_id = null
    assign show_class = ''
    assign product_color = '#f1b434'

    if product.metafields.custom.color != blank
      assign product_color = product.metafields.custom.color
    endif

    if product.variants != blank
      for variant in product.variants
        if settings.default_variants contains variant.title
          assign default_variant_id = variant.id
        endif
        if variant.selected == true
          assign default_variant_id = variant.id
        endif
      endfor
      if default_variant_id == null
        for variant in product.variants
          if variant == product.selected_or_first_available_variant
            assign default_variant_id = variant.id
          endif
        endfor
      endif
    endif
  %}
  {% if section.settings.dropdown %}
    {{ 'variant-swatches.css' | asset_url | stylesheet_tag }}

  {% endif %}

  <div class="c-product__content  sss" data-product-color="{{ product_color }}">
    <div class="c-product__left">
      {%- if featured_media != null -%}
        <div class="c-product__slider swiper">
          <div class="c-product__slider__wrapper swiper-wrapper">
            {%- if featured_media != null -%}
              <div class="c-product__image swiper-slide">
                <div class="c-product__image__wrapper u-absolute-fill{% if product.selected_or_first_available_variant.id != blank and product.variants.size > 1 %} show-variant{% endif %}">
                  <div class="c-product__image__main u-absolute-fill">
                    <a
                      data-id="{{ featured_media.id }}"
                      data-fancybox="gallery"
                      data-src="{{ featured_media | image_url: width: 1600 }}"
                      class="c-product__image__featured u-absolute-fill"
                    >
                      {{
                        featured_media
                        | image_url: width: featured_media.width
                        | image_tag:
                          height: featured_media.height,
                          alt: featured_media.alt,
                          class: 'u-absolute-fill',
                          loading: 'lazy'
                      }}
                    </a>
                  </div>
                      {% assign badge_image = product.metafields.custom.badge_image.value %}
                      {% assign badge_link = product.metafields.custom.badge_link.value %}

                      {% if badge_image != blank %}
                        <div class="product-badge">
                          {% if badge_link != blank %}
                            <a href="{{ badge_link }}" target="_blank" rel="noopener">
                              <img 
                                src="{{ badge_image }}" 
                                alt="Badge" 
                                loading="lazy"
                              >
                            </a>
                          {% else %}
                            <img 
                              src="{{ badge_image }}" 
                              alt="Badge" 
                              loading="lazy"
                            >
                          {% endif %}
                        </div>
                      {% endif %}

                  {%- if product.variants != blank -%}
                    <div class="c-product__image__variants u-absolute-fill">
                      {%- for variant in product.variants -%}
                        {% liquid
                          if product.selected_or_first_available_variant == variant
                            assign show_class = 'u-absolute-fill c-product__image__variant show-variant-image'
                          else
                            assign show_class = 'u-absolute-fill c-product__image__variant'
                          endif
                        %}
                        {%- if variant.featured_media != blank -%}
                          <a
                            data-id="{{ variant.featured_media.id }}"
                            data-fancybox="gallery"
                            data-src="{{ variant.featured_media | image_url: width: 1600 }}"
                            class="{{ show_class }}"
                            data-variant-id="{{ variant.id }}"
                          >
                            {{
                              variant.featured_media
                              | image_url: width: variant.featured_media.width
                              | image_tag:
                                height: variant.featured_media.height,
                                alt: variant.featured_media.alt,
                                class: 'u-absolute-fill',
                                loading: 'lazy'
                            }}
                          </a>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
                {%- if product.metafields.custom.background_image != blank -%}
                  {{
                    product.metafields.custom.background_image
                    | image_url: width: product.metafields.custom.background_image.width
                    | image_tag:
                      height: product.metafields.custom.background_image.height,
                      alt: product.metafields.custom.background_image.alt,
                      class: 'c-product__image__background',
                      loading: 'lazy'
                  }}
                {%- endif -%}
              </div>
            {%- endif -%}
            {%- if product.media.size > 1 -%}
              {%- for media in product.media -%}
                {%- unless media.id == product.selected_or_first_available_variant.featured_media.id
                  or media.alt contains 'variant'
                -%}
                  <div class="swiper-slide c-product__slider__item">
                    <a
                      data-id="{{ media.id }}"
                      data-fancybox="gallery"
                      data-src="{% if media.media_type == 'image' %}{{ media | image_url: width: 1600 }}{% else if media.media_type == "external_video" %}{% if media.host == 'youtube' %}https://www.youtube.com/watch?v={% else %}https://vimeo.com/{% endif %}{{ media.external_id }}{% endif %}"
                      class="c-product__gallery__item{% if media.media_type == "external_video" %} jarallax jarallax-mobile{% endif %}"
                    >
                      {% if media.media_type == 'external_video' %}
                        <div class="c-product__gallery__icon">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <polygon points="5 3 19 12 5 21 5 3"></polygon>
                          </svg>
                        </div>
                      {% else %}
                        <div class="c-product__gallery__icon is-zoom">
                          <svg
                            viewBox="0 0 24 24"
                            width="24"
                            height="24"
                            stroke="currentColor"
                            stroke-width="2"
                            fill="none"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="css-i6dzq1"
                          >
                            <line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line>
                          </svg>
                        </div>
                      {% endif %}
                      {% if media.media_type == 'external_video' %}
                        {{
                          media
                          | image_url: width: media.width
                          | image_tag:
                            height: media.height,
                            alt: media.alt,
                            class: 'c-product__gallery__img jarallax-img',
                            loading: 'lazy'
                        }}
                      {% else %}
                        {{
                          media
                          | image_url: width: media.width
                          | image_tag:
                            height: media.height,
                            alt: media.alt,
                            class: 'c-product__gallery__img',
                            loading: 'lazy'
                        }}
                      {% endif %}
                    </a>
                  </div>
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
          <div class="c-product__slider__nav c-product__slider__nav--prev swiper-button-prev">
            {%- render 'icon-arrow', type: 'left' -%}
          </div>
          <div class="c-product__slider__nav c-product__slider__nav--next swiper-button-next">
            {%- render 'icon-arrow', type: 'right' -%}
          </div>
        </div>
      {%- endif -%}
      {%- if product.media.size > 1 -%}
       <div class="c-product__gallery">
  {%- for media in product.media -%}
    {%- if forloop.index > 1 -%}  <!-- Skip the first image -->
      {%- if media.id != product.selected_or_first_available_variant.featured_media.id -%}
        {%- unless media.alt contains 'variant' -%}
          <a
            data-id="{{ media.id }}"
            data-fancybox="gallery"
            data-src="{% if media.media_type == 'image' %}{{ media | image_url: width: 1600 }}{% elsif media.media_type == 'external_video' %}{% if media.host == 'youtube' %}https://www.youtube.com/watch?v={{ media.external_id }}{% else %}https://vimeo.com/{{ media.external_id }}{% endif %}{% endif %}"
            class="c-product__gallery__item{% if media.media_type == 'external_video' %} jarallax jarallax-desktop{% endif %}"
          >
            {% if media.media_type == 'external_video' %}
              <div class="c-product__gallery__icon">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
              </div>
            {% endif %}

            {% if media.media_type == 'external_video' %}
              {{
                media
                | image_url: width: media.width
                | image_tag:
                  height: media.height,
                  alt: media.alt,
                  class: 'c-product__gallery__img jarallax-img',
                  loading: 'lazy'
              }}
            {% else %}
              {{
                media
                | image_url: width: media.width
                | image_tag:
                  height: media.height,
                  alt: media.alt,
                  class: 'c-product__gallery__img',
                  loading: 'lazy'
              }}
            {% endif %}
          </a>
        {%- endunless -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
	</div>
      {%- endif -%}
    </div>
    <div class="c-product__right">
      <div class="c-product__info-top">
        <div class="c-product__title">
  {%- if product.metafields.custom.product_name != blank -%}
    <h1>
      {{ product.metafields.custom.product_name | escape }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
        </span>
      {%- endif -%}
      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- elsif product.title != blank -%}
    <h1>
      {{ product.title | escape }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
        </span>
      {%- endif -%}
      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- else -%}
    <h1>
      {{ 'sections.main_product.manuka_honey' | t }}
      {%- if product.metafields.custom.umf_score != blank -%}
        <span class="c-product__score c-product__score--umf">
          <span class="c-product__score__name">{{ 'sections.main_product.umf_html' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.umf_score | escape }}</span>
        </span>
      {%- endif -%}
      {%- if product.metafields.custom.mgo_score != blank -%}
        <span class="c-product__score c-product__score--mgo">
          <span class="c-product__score__name">{{ 'sections.main_product.mgo' | t }}</span>
          <span class="c-product__score__value">{{ product.metafields.custom.mgo_score | escape }}</span>
        </span>
      {%- endif -%}
    </h1>
    {% if product.metafields.custom.sale_badges != blank %}
      <div class="sale-badge">{{ product.metafields.custom.sale_badges }}</div>
    {% endif %}
  {%- endif -%}
</div>
        {% if product.metafields.custom.help_me_pick %}
