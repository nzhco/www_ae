    <div class="c-home-banner__buttons">
      <div class="c-home-banner__button c-home-banner__button--left">
        {%- if section.settings.text_1 != blank -%}
          <p>{{ section.settings.text_1 | escape }}</p>
        {%- endif -%}
        {%- if section.settings.button_1_label != blank and section.settings.button_1_link -%}
