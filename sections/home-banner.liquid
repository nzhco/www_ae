{% schema %}
{
  "name": "Home Banner",
  "tag": "section",
  "class": "c-home-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "video_url",
      "id": "bg_video",
      "label": "Background Video",
      "default": "https://www.youtube.com/watch?v=r4wNFNe1k-s",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Background Image Mobile"
    },
    {
      "type": "image_picker",
      "id": "svg_image",
      "label": "Text Image"
    },
    {
      "type": "checkbox",
      "id": "hide_image_text",
      "label": "Hide image text",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "On a health buzz"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1",
      "default": "Our Manuka Honey"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2",
      "default": "Which Manuka is for me?"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label",
      "default": "Take our quiz"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
  "type": "text",
  "id": "global_reviews_text",
  "label": "Global Reviews Text",
  "default": "20,407+ Verified Global Reviews"
}
  ],
  "presets": [
    {
      "name": "Home Banner"
    }
  ]
}
{% endschema %}