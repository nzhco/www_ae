            href="{{ section.settings.button_1_link }}"
            class="c-button c-button--white c-button--home-banner"
            rel="bookmark"
          >
            {{- section.settings.button_1_label | escape -}}
          </a>
        {%- endif -%}
      </div>
      <div class="c-home-banner__button c-home-banner__button--right">
        {%- if section.settings.text_2 != blank -%}
          <p>{{ section.settings.text_2 | escape }}</p>
        {%- endif -%}
        {%- if section.settings.button_2_label != blank and section.settings.button_2_link -%}
