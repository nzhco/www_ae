{{ 'newsletter.css' | asset_url | stylesheet_tag }}

{% if section.settings.title_image != blank or shop.metaobjects.svgs['svgs-wjxuznox'].join_the_hive_community.value != blank %}
  <style>
    .c-newsletter__form__button > img {
      width: 100%;
      height: auto;
  }
  </style>
  {% endif %}

<svg
  class="c-newsletter__top"
  width="1437"
  height="125"
  viewBox="0 0 1437 125"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <path d="M502 90C252 16 111 29 0 56V0H1437V37C1318 0.999969 1192 2.54544 1120 26C953 80.4016 791 175.544 502 90Z" fill="{{ section.settings.bg_color }}"/>
</svg>
<div class="c-container">
  {% form 'customer', class: 'c-newsletter__form' %}
    <input type="hidden" name="utf8" value="✓">
    <input type="hidden" name="contact[tags]" value="newsletter{% if request.locale.iso_code == 'ar' %},tag_ar{% endif %}">
    <input type="hidden" name="contact[source]" value="Newsletter Subscription Form">
    <div class="c-newsletter__form__field">
      {%- if section.settings.paragraph != blank -%}
        <div class="c-newsletter__form__description">
          <p>{{ section.settings.paragraph | escape }}</p>
        </div>
      {%- endif -%}
      <div class="c-newsletter__form__field__email">
        <input
          id="NewsletterForm"
          type="email"
          name="contact[email]"
          class="field__input"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          {% if form.errors %}
            autofocus aria-invalid="true" aria-describedby="Newsletter-error"
          {% elsif form.posted_successfully? %}
            aria-describedby="Newsletter-success"
          {% endif %}
          placeholder="{{ 'sections.newsletter.email_address' | t }}"
          required
        >
        <label class="c-newsletter__form__label u-hidden" for="NewsletterForm">
          {{- 'sections.newsletter.email_address' | t -}}
        </label>
        <button
          type="submit"
          class="c-newsletter__form__btn"
          name="commit"
          id="Subscribe"
          aria-label="Subscribe"
        >
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            stroke="currentColor"
            stroke-width="2"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="css-i6dzq1"
          >
            <line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </div>
      <div class="c-newsletter__form__message">
        {%- if form.errors -%}
          <p class="c-newsletter__form__message__error" id="Newsletter-error">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
      </div>
    </div>
    <div class="c-newsletter__form__button">
      {% if section.settings.title_image != blank %}
        <img src="{{ section.settings.title_image | image_url }}">
      {% elsif shop.metaobjects.svgs['svgs-wjxuznox'].join_the_hive_community.value != blank %}
        <img src="{{ shop.metaobjects.svgs['svgs-wjxuznox'].join_the_hive_community.value | image_url }}">
        {% else %}
      <svg
        fill="none"
        height="216"
        viewbox="0 0 650 216"
        width="650"
        xmlns="http://www.w3.org/2000/svg"
