    </div>
    {%- if form.posted_successfully? -%}
      <p class="c-newsletter__form__message__success" id="Newsletter-success" tabindex="-1">
        {% if section.settings.success != blank -%}
          {{- section.settings.success | escape -}}
        {%- else -%}
          {{ 'sections.newsletter.thanks' | t }}
        {%- endif %}
      </p>
    {%- endif -%}
  {% endform %}
</div>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "c-newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "title_image",
      "label": "Graphic Title"
    },
    {
      "type": "text",
      "id": "paragraph",
      "label": "Form Title",
      "default": "Enter your email to receive 10% off your next order and be the first to know about our sales, news and events!"
    },
    {
      "type": "text",
      "id": "success",
      "label": "Sucess Message",
      "default": "Thanks for subscribing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FBF9F6"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
