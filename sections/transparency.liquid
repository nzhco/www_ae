{{ 'transparency.css' | asset_url | stylesheet_tag }}

{% if section.settings.title_image != blank or shop.metaobjects.svgs['svgs-wjxuznox'].eyes_on_the_hives.value != blank %}
  <style>
    .c-container .c-transparency__right img.c-quality__image {
      width: 100%;
      height: auto;
      position: relative;
      z-index: 2;
      padding-top: 20%;
      padding-bottom: 20%;
  }

    .c-container .c-transparency__right__title {
      position: absolute;
      z-index: 3;
      width: 70%;
      height: auto;
      left: -50%;
      top: 0;
      padding-top: 0;
      padding-bottom: 0;
  }

    @media only screen and (max-width: 1199px) {
      .c-container .c-transparency__right__title {
        left: 0;
      }
    }
  </style>
  {% endif %}

<script src="{{ 'transparency.js' | asset_url }}" defer="defer"></script>
<div class="c-container">
  <div class="c-transparency__content">
    <div class="c-transparency__left">
      {%- if section.settings.title != blank -%}
        <h2>{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p>{{ section.settings.description }}</p>
      {%- endif -%}
      {%- if section.blocks != blank -%}
        <div class="c-transparency__items">
          {%- for block in section.blocks -%}
            <div class="c-transparency__item">
              {%- if block.settings.title != blank and block.settings.description != blank -%}
                <div class="c-transparency__item__title">
                  <h3>{{ block.settings.title }}</h3>
                  {%- render 'icon-arrow', type: '' -%}
                </div>
                <div class="c-transparency__item__description">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if section.settings.footer != blank -%}
        <p>{{ section.settings.footer }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_link -%}
        <p>
          <a href="{{ section.settings.button_link }}" class="c-button c-button--white" rel="bookmark">
            {{- section.settings.button_label -}}
          </a>
        </p>
      {%- endif -%}
    </div>
    <div class="c-transparency__right">
      {% if section.settings.title_image != blank %}
        <img class="c-transparency__right__title" src="{{ section.settings.title_image | image_url }}">
      {% elsif shop.metaobjects.svgs['svgs-wjxuznox'].eyes_on_the_hives.value != blank %}
        <img class="c-transparency__right__title" src="{{ shop.metaobjects.svgs['svgs-wjxuznox'].eyes_on_the_hives.value | image_url }}">
        {% else %}
      <svg class="c-transparency__right__title" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 464.9 332.79">
