{% schema %}
{
  "name": "Transparency",
  "tag": "section",
  "class": "c-transparency",
  "blocks": [
    {
      "type": "content",
      "name": "Content",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Tracked from Hive to Home",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>To view the UMF™ Certificate specific to your jar of authentic Manuka Honey scan the QR Code on the back of the jar with your mobile phone.</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "title_image",
      "label": "Graphic Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "We are dedicated to transparency"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We put the power in your hands with each and every jar.</p>"
    },
    {
      "type": "richtext",
      "id": "footer",
      "label": "Footer",
      "default": "<p>To view the UMF™ Certificate specific to your jar of authentic Manuka Honey scan the QR Code on the back of the jar with your mobile phone.<p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Find out more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Image"
    }
  ],
  "presets": [
    {
      "name": "Transparency"
    }
  ]
}
{% endschema %}
