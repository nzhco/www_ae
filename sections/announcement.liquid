{{ 'announcement.css' | asset_url | stylesheet_tag }}
<div
  class="announcement-wrapper"
  {% if section.settings.color_text and section.settings.color_bg %}
    style="--an-color: {{ section.settings.color_text }}; --an-bg: {{ section.settings.color_bg }};"
  {% endif %}
>
  {%- if section.settings.link != blank -%}
    <a
      href="{{ section.settings.link }}"
      class="announcement-link"
      rel="bookmark"
      {% if section.settings.color_text %}
        style="--an-color: {{ section.settings.color_text }};"
      {% endif %}
    >
      <div class="c-container">
        <div class="announcement-text">
          <span>{{ section.settings.text }}</span>
          {%- if section.settings.icon -%}
            <svg
              width="100%"
              height="100%"
              viewBox="0 0 24 24"
              version="1.1"
              xmlns="http://www.w3.org/2000/svg"
              xmlns:xlink="http://www.w3.org/1999/xlink"
              xml:space="preserve"
              xmlns:serif="http://www.serif.com/"
              style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;"
            >
              <g transform="matrix(0.471041,0,0,0.490683,0.223978,0.199081)">
                  <path d="M35.1,32.95L32.95,30.85L38.25,25.55L6,25.55L6,22.55L38.3,22.55L33,17.25L35.1,15.15L44,24.05L35.1,32.95Z" style="fill-rule:nonzero;"/>
              </g>
            </svg>
          {% endif %}
        </div>
      </div>
    </a>
  {%- else -%}
    <div class="c-container">
      <div class="announcement-text">
        <span>{{ section.settings.text }}</span>
        {%- if section.settings.icon -%}
          <svg
            width="100%"
            height="100%"
            viewBox="0 0 24 24"
            version="1.1"
            xmlns="http://www.w3.org/2000/svg"
            xmlns:xlink="http://www.w3.org/1999/xlink"
            xml:space="preserve"
            xmlns:serif="http://www.serif.com/"
            style="fill-rule:evenodd;clip-rule:evenodd;stroke-linejoin:round;stroke-miterlimit:2;"
          >
            <g transform="matrix(0.471041,0,0,0.490683,0.223978,0.199081)">
                <path d="M35.1,32.95L32.95,30.85L38.25,25.55L6,25.55L6,22.55L38.3,22.55L33,17.25L35.1,15.15L44,24.05L35.1,32.95Z" style="fill-rule:nonzero;"/>
            </g>
          </svg>
        {% endif %}
      </div>
    </div>
  {%- endif -%}
</div>
{% schema %}
{
  "name": "Announcement",
  "tag": "section",
  "class": "announcement-bar",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Our Manuka Honey</p>"
    },
    {
      "type": "url",
      "id": "link",
      "label": "link"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Color text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Color Background",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "icon",
      "label": "Show icon",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement"
    }
  ]
}
{% endschema %}
